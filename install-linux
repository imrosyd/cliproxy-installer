# ── Source Shell Configuration ──
source_shell_config() {
    echo -e "${YELLOW}Reloading shell configuration...${NC}"
    
    if [[ "$SHELL" == *"zsh"* ]]; then
        [ -f "$HOME/.zshrc" ] && source "$HOME/.zshrc" 2>/dev/null
    elif [[ "$SHELL" == *"fish"* ]]; then
        [ -f "$HOME/.config/fish/config.fish" ] && source "$HOME/.config/fish/config.fish" 2>/dev/null
    else
        [ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc" 2>/dev/null
    fi
    
    echo -e "${GREEN}[OK] Shell configuration loaded!${NC}"
}

setup_shortcuts() {
    SHELL_CONFIG="$HOME/.bashrc"
    if [[ "$SHELL" == *"zsh"* ]]; then
        SHELL_CONFIG="$HOME/.zshrc"
    elif [[ "$SHELL" == *"fish"* ]]; then
        # Fish uses different syntax - create fish config
        FISH_CONFIG="$HOME/.config/fish/config.fish"
        mkdir -p "$(dirname "$FISH_CONFIG")"

        echo -e "${YELLOW}Adding shortcuts for Fish shell to $FISH_CONFIG...${NC}"

        # Remove old aliases
        sed -i '/alias cp-login/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-start/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-stop/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-update/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-login-url/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-claude/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-db/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-antigravity/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-opencode/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-droid/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-uninstall/d' "$FISH_CONFIG" 2>/dev/null || true

        # Add new aliases (Fish syntax)
        echo "" >> "$FISH_CONFIG"
        echo "# CLIProxy Shortcuts" >> "$FISH_CONFIG"
        echo "alias cp-login='$HOME/.cliproxyapi/scripts/login.sh'" >> "$FISH_CONFIG"
        echo "alias cp-login-url='$HOME/.cliproxyapi/scripts/login-url.sh'" >> "$FISH_CONFIG"
        echo "alias cp-start='$HOME/.cliproxyapi/scripts/start.sh'" >> "$FISH_CONFIG"
        echo "alias cp-stop='$HOME/.cliproxyapi/scripts/stop.sh'" >> "$FISH_CONFIG"
        echo "alias cp-update='curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/install-linux | bash -s -- -update'" >> "$FISH_CONFIG"
        echo "alias cp-claude='$HOME/.cliproxyapi/scripts/cp-claude.sh'" >> "$FISH_CONFIG"
        echo "alias cp-db='$HOME/.cliproxyapi/bin/cp-db'" >> "$FISH_CONFIG"
        echo "alias cp-antigravity='$HOME/.cliproxyapi/scripts/cp-antigravity.sh'" >> "$FISH_CONFIG"
        echo "alias cp-opencode='$HOME/.cliproxyapi/scripts/cp-opencode.sh'" >> "$FISH_CONFIG"
        echo "alias cp-droid='$HOME/.cliproxyapi/scripts/cp-droid.sh'" >> "$FISH_CONFIG"
        echo "alias cp-uninstall='curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/uninstall | bash'" >> "$FISH_CONFIG"

        echo -e "${GREEN}[OK] Fish shortcuts added!${NC}"
        
        # Immediately source the config for Fish
        [ -f "$FISH_CONFIG" ] && source "$FISH_CONFIG" 2>/dev/null
        return
    fi

    echo -e "${YELLOW}Adding shortcuts to $SHELL_CONFIG...${NC}"

    # Remove all old aliases before re-adding (prevents duplicates across installs)
    sed -i '/alias cp-login/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-login-url/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-start/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-stop/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-update/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-claude/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-db/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-antigravity/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-opencode/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-droid/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-add-provider/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-uninstall/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/# CLIProxy Shortcuts/d' "$SHELL_CONFIG" 2>/dev/null || true

    # Add new aliases
    echo "" >> "$SHELL_CONFIG"
    echo "# CLIProxy Shortcuts" >> "$SHELL_CONFIG"
    echo "alias cp-login=\"$HOME/.cliproxyapi/scripts/login.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-login-url=\"$HOME/.cliproxyapi/scripts/login-url.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-start=\"$HOME/.cliproxyapi/scripts/start.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-stop=\"$HOME/.cliproxyapi/scripts/stop.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-update=\"curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/install-linux | bash -s -- -update\"" >> "$SHELL_CONFIG"
    echo "alias cp-claude=\"$HOME/.cliproxyapi/scripts/cp-claude.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-db=\"$HOME/.cliproxyapi/bin/cp-db\"" >> "$SHELL_CONFIG"
    echo "alias cp-antigravity=\"$HOME/.cliproxyapi/scripts/cp-antigravity.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-opencode=\"$HOME/.cliproxyapi/scripts/cp-opencode.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-kilo=\"$HOME/.cliproxyapi/scripts/cp-kilo.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-droid=\"$HOME/.cliproxyapi/scripts/cp-droid.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-uninstall=\"curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/uninstall | bash\"" >> "$SHELL_CONFIG"

    echo -e "${GREEN}[OK] Shortcuts added!${NC}"
    
    # Immediately source the config so aliases are available
    [ -f "$SHELL_CONFIG" ] && source "$SHELL_CONFIG" 2>/dev/null
}

clean_existing_configs() {
    echo -e "${YELLOW}>>> Cleaning existing configurations...${NC}"
    
    # Check if there's existing config/auth data to preserve
    CONFIG_DIR="$HOME/.cliproxyapi"
    HAS_EXISTING_CONFIG=false
    HAS_EXISTING_AUTH=false
    clean_choice="1"  # Default to preserve if non-interactive
    
    if [ -f "$CONFIG_DIR/config.yaml" ]; then
        HAS_EXISTING_CONFIG=true
    fi
    
    # Check for auth files (json files in config dir)
    if [ -d "$CONFIG_DIR" ] && [ "$(ls -1 "$CONFIG_DIR"/*.json 2>/dev/null | wc -l)" -gt 0 ]; then
        HAS_EXISTING_AUTH=true
    fi
    
    # If existing config/auth found, offer to preserve (only if interactive)
    if [ "$HAS_EXISTING_CONFIG" = true ] || [ "$HAS_EXISTING_AUTH" = true ]; then
        # Check if running interactively (has a terminal)
        if [ -t 0 ]; then
            echo -e "${YELLOW}[!] Existing CLIProxy configuration detected!${NC}"
            echo ""
            echo -e "  ${GREEN}1${NC}  Preserve existing config & auth (Recommended)"
            echo -e "  ${RED}2${NC}  Clean install (delete all data)"
            echo ""
            echo -ne "  ${BOLD}›${NC} Select ${DIM}(1-2)${NC}: "
            read clean_choice < /dev/tty
        else
            echo -e "${CYAN}[i] Non-interactive mode: auto-preserving existing config & auth${NC}"
            clean_choice="1"
        fi
        
        if [ "$clean_choice" = "1" ]; then
            echo -e "${CYAN}[i] Preserving existing configuration...${NC}"
            
            # Backup to a fixed location (not using $$ which can cause issues)
            BACKUP_DIR="$HOME/.cliproxyapi_backup"
            rm -rf "$BACKUP_DIR"
            mkdir -p "$BACKUP_DIR"
            
            # Copy config
            if [ -f "$CONFIG_DIR/config.yaml" ]; then
                cp "$CONFIG_DIR/config.yaml" "$BACKUP_DIR/config.yaml"
                echo -e "  ${DIM}Backed up config.yaml${NC}"
            fi
            
            # Copy auth files
            if [ -d "$CONFIG_DIR" ]; then
                for f in "$CONFIG_DIR"/*.json; do
                    [ -f "$f" ] && cp "$f" "$BACKUP_DIR/"
                done
                echo -e "  ${DIM}Backed up auth files${NC}"
            fi
            
            echo -e "${YELLOW}>>> Cleaning for fresh install...${NC}"
        fi
    else
        echo -e "${DIM}No existing configuration found, clean install${NC}"
    fi
    
    # Always clean (remove directory)
    if [ -d "$HOME/.cliproxyapi" ]; then
        echo -e "  ${DIM}Removing ~/.cliproxyapi...${NC}"
        rm -rf "$HOME/.cliproxyapi"
    fi

    # Legacy directory
    if [ -d "$HOME/.cli-proxy-api" ]; then
        echo -e "  ${DIM}Removing legacy ~/.cli-proxy-api...${NC}"
        rm -rf "$HOME/.cli-proxy-api"
    fi

    # Clean old binary locations
    rm -f "$HOME/bin/cliproxyapi" 2>/dev/null
    rm -f "$HOME/bin/cliproxyapi-plus" 2>/dev/null
    rm -f "$HOME/bin/cp-db" 2>/dev/null
    rm -f "/usr/local/bin/cp-db" 2>/dev/null || true

    # Clean old PATH entries for ~/bin if empty
    if [ -d "$HOME/bin" ] && [ -z "$(ls -A "$HOME/bin" 2>/dev/null)" ]; then
        rmdir "$HOME/bin" 2>/dev/null || true
    fi

    # Keep external tool configs
    [ -f "$HOME/.config/opencode/opencode.json" ] && echo -e "  ${DIM}Preserving ~/.config/opencode/opencode.json${NC}"
    [ -f "$HOME/.claude/settings.json" ] && echo -e "  ${DIM}Preserving ~/.claude/settings.json${NC}"
    [ -f "$HOME/.factory/config.json" ] && echo -e "  ${DIM}Preserving ~/.factory/config.json${NC}"

    # Restore backup if preserve was chosen
    if [ "$clean_choice" = "1" ] && [ -d "$HOME/.cliproxyapi_backup" ]; then
        echo -e "${CYAN}[i] Restoring preserved configuration...${NC}"
        mkdir -p "$CONFIG_DIR"
        
        # Restore config
        if [ -f "$HOME/.cliproxyapi_backup/config.yaml" ]; then
            cp "$HOME/.cliproxyapi_backup/config.yaml" "$CONFIG_DIR/config.yaml"
            echo -e "  ${DIM}Restored config.yaml${NC}"
        fi
        
        # Restore auth files
        for f in "$HOME/.cliproxyapi_backup"/*.json; do
            [ -f "$f" ] && cp "$f" "$CONFIG_DIR/"
        done
        echo -e "  ${DIM}Restored auth files${NC}"
        
        # Clean up backup
        rm -rf "$HOME/.cliproxyapi_backup"
        echo -e "${GREEN}[OK] Existing configuration preserved!${NC}"
    fi
    
    echo -e "${GREEN}[OK] All old configurations cleared.${NC}"
}

install_cliproxy() {
    IS_UPDATE="${1:-false}"
    FORCE_CLEAN="${2:-false}"

    if ! command -v go &> /dev/null; then
        echo -e "${RED}[Error] Go is not found!${NC}"
        echo "Please run option 1 to install dependencies first."
        exit 1
    fi

    # Set CONFIG_DIR
    CONFIG_DIR="$HOME/.cliproxyapi"
    BIN_DIR="$CONFIG_DIR/bin"
    SCRIPTS_DIR="$CONFIG_DIR/scripts"

    install_asset() {
        local label="$1"
        local local_rel="$2"
        local url="$3"
        local dest="$4"
        local chmod_exec="${5:-true}"

        echo -e "${YELLOW}Installing ${label}...${NC}"
        local src
        src="$(dirname "$0")/${local_rel}"
        if [ -f "$src" ]; then
            cp "$src" "$dest"
            echo -e "${GREEN}[OK] ${label} installed from local assets${NC}"
        else
            if curl -fsSL "$url" -o "$dest" 2>/dev/null; then
                echo -e "${GREEN}[OK] ${label} downloaded from GitHub${NC}"
            else
                echo -e "${YELLOW}[!] Could not install ${label}${NC}"
                return 1
            fi
        fi

        if [ "$chmod_exec" = "true" ]; then
            chmod +x "$dest" 2>/dev/null || true
        fi
        return 0
    }

    install_cliproxy_assets() {
        mkdir -p "$BIN_DIR" "$CONFIG_DIR" "$SCRIPTS_DIR"
        STATIC_DIR="$CONFIG_DIR/static"
        mkdir -p "$STATIC_DIR"

        install_asset "script library" "assets/scripts/cp-lib.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-lib.sh" \
            "$SCRIPTS_DIR/cp-lib.sh" true

        install_asset "dashboard" "assets/static/dashboard.html" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/static/dashboard.html" \
            "$STATIC_DIR/dashboard.html" false

        install_asset "quota fetcher" "assets/scripts/quota-fetcher.py" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/quota-fetcher.py" \
            "$SCRIPTS_DIR/quota-fetcher.py" true

        install_asset "unified server" "unified-server.py" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/unified-server.py" \
            "$SCRIPTS_DIR/unified-server.py" true

        install_asset "cp-db" "assets/scripts/cp-db.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-db.sh" \
            "$BIN_DIR/cp-db" true

        install_asset "cp-claude" "assets/scripts/cp-claude.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-claude.sh" \
            "$SCRIPTS_DIR/cp-claude.sh" true

        install_asset "cp-antigravity python script" "assets/scripts/cp-antigravity.py" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-antigravity.py" \
            "$SCRIPTS_DIR/cp-antigravity.py" true

        install_asset "cp-antigravity script" "assets/scripts/cp-antigravity.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-antigravity.sh" \
            "$SCRIPTS_DIR/cp-antigravity.sh" true

        install_asset "cp-opencode" "assets/scripts/cp-opencode.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-opencode.sh" \
            "$SCRIPTS_DIR/cp-opencode.sh" true

        install_asset "cp-kilo" "assets/scripts/cp-kilo.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-kilo.sh" \
            "$SCRIPTS_DIR/cp-kilo.sh" true

        install_asset "cp-droid" "assets/scripts/cp-droid.sh" \
            "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-droid.sh" \
            "$SCRIPTS_DIR/cp-droid.sh" true
    }
    
    # Check if existing config/auth exists - if yes, skip entirely (never overwrite)
    HAS_EXISTING=false
    if [ -d "$CONFIG_DIR" ]; then
        if [ -f "$CONFIG_DIR/config.yaml" ]; then
            HAS_EXISTING=true
            echo -e "${CYAN}[i] Found existing config.yaml${NC}"
        fi
        if [ "$(ls -1 "$CONFIG_DIR"/*.json 2>/dev/null | wc -l)" -gt 0 ]; then
            HAS_EXISTING=true
            echo -e "${CYAN}[i] Found existing auth files (.json)${NC}"
        fi
    fi
    
    if [ "$HAS_EXISTING" = true ]; then
        if [ "$IS_UPDATE" = "true" ]; then
            echo -e "${CYAN}[i] Updating CLIProxy assets (preserve config/auth)${NC}"
            install_cliproxy_assets
            echo -e "${GREEN}[OK] Assets updated.${NC}"
        else
            echo -e "${CYAN}[i] CLIProxy already installed with config/auth${NC}"
            echo -e "${CYAN}[i] To reinstall fresh, please uninstall first: curl -fsSL .../install-linux | bash -s -- -uninstall-cliproxy${NC}"
            echo -e "${GREEN}[OK] Existing installation preserved.${NC}"
        fi
        return 0
    fi

    echo -e "${YELLOW}>>> Starting CLIProxy Installation...${NC}"

    # Ensure bin is in PATH
    if [[ ":$PATH:" != *":$CONFIG_DIR/bin:"* ]] && [[ ":$PATH:" != *":$HOME/.cliproxyapi/bin:"* ]]; then
        echo 'export PATH="$HOME/.cliproxyapi/bin:$PATH"' >> "$HOME/.bashrc"
        [ -f "$HOME/.zshrc" ] && echo 'export PATH="$HOME/.cliproxyapi/bin:$PATH"' >> "$HOME/.zshrc"
        [ -f "$HOME/.config/fish/config.fish" ] && echo 'set -gx PATH $HOME/.cliproxyapi/bin $PATH' >> "$HOME/.config/fish/config.fish"
        echo -e "${YELLOW}[!] Added $HOME/.cliproxyapi/bin to PATH.${NC}"
    fi
    install_cliproxy_assets


    # Clone & Build
    TEMP_DIR=$(mktemp -d)
    echo -e "${YELLOW}Cloning repository...${NC}"
    if ! git clone --depth 1 https://github.com/router-for-me/CLIProxyAPIPlus.git "$TEMP_DIR"; then
        echo -e "${RED}[Error] Failed to clone repository${NC}"
        rm -rf "$TEMP_DIR"
        exit 1
    fi

    echo -e "${YELLOW}Building binary...${NC}"
    cd "$TEMP_DIR"
    if ! go build -o cliproxyapi ./cmd/server; then
        echo -e "${RED}[Error] Failed to build binary${NC}"
        cd -
        rm -rf "$TEMP_DIR"
        exit 1
    fi
    mv -f cliproxyapi "$BIN_DIR/cliproxyapi"
    cd -
    rm -rf "$TEMP_DIR"

    echo -e "${GREEN}[OK] Binary built and installed successfully.${NC}"

    # Config
    # Only create if it doesn't exist, to preserve user settings on update
    if [ ! -f "$CONFIG_DIR/config.yaml" ]; then
        # Ask for optional baseURL and apiKey configuration
        echo ""
        echo -e "${YELLOW}${BOLD}  ── Optional: Custom Base URL & API Key ──${NC}"
        echo -e "  ${DIM}Configure a custom base URL and API key.${NC}"
        echo -e "  ${DIM}Press Enter to skip and use defaults (localhost:8317, sk-dummy)${NC}"
        echo ""
        
        read -p "Configure custom base URL and API key? (y/n): " configure_custom < /dev/tty
        
        CUSTOM_BASE_URL=""
        CUSTOM_API_KEY=""
        
        if [[ "$configure_custom" =~ ^[Yy]$ ]]; then
            echo ""
            read -p "Enter base URL (e.g., http://localhost:8317): " CUSTOM_BASE_URL < /dev/tty
            read -p "Enter API key (e.g., sk-your-key): " CUSTOM_API_KEY < /dev/tty
            
            # Use defaults if empty
            if [ -z "$CUSTOM_BASE_URL" ]; then
                CUSTOM_BASE_URL="http://localhost:8317"
            fi
            if [ -z "$CUSTOM_API_KEY" ]; then
                CUSTOM_API_KEY="sk-dummy"
            fi
            
            echo -e "${GREEN}[OK] Using custom configuration${NC}"
            echo -e \"  ${DIM}Base URL: $CUSTOM_BASE_URL${NC}\"
            echo -e \"  ${DIM}API Key: $CUSTOM_API_KEY${NC}\"
        else
            CUSTOM_BASE_URL=\"http://localhost:8317\"
            CUSTOM_API_KEY=\"sk-dummy\"
            echo -e \"${DIM}[i] Using default configuration${NC}\"
        fi
        
        cat > "$CONFIG_DIR/config.yaml" <<EOF
port: 8317
auth-dir: "$CONFIG_DIR"
api-keys:
  - "$CUSTOM_API_KEY"
remote-management:
  allow-remote: true
  secret-key: "$CUSTOM_API_KEY"
quota-exceeded:
  switch-project: true
  switch-preview-model: true
EOF
        echo -e "${GREEN}[OK] Created config.yaml${NC}"
        
        # Store base URL for later use if custom
        if [ "$CUSTOM_BASE_URL" != "http://localhost:8317" ]; then
            echo "$CUSTOM_BASE_URL" > "$CONFIG_DIR/.custom_base_url"
            echo "$CUSTOM_API_KEY" > "$CONFIG_DIR/.custom_api_key"
        fi
    fi

    install_asset "stop script" "assets/scripts/stop.sh" \
        "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/stop.sh" \
        "$SCRIPTS_DIR/stop.sh" true

    install_asset "start script" "assets/scripts/start.sh" \
        "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/start.sh" \
        "$SCRIPTS_DIR/start.sh" true

    install_asset "login script" "assets/scripts/login.sh" \
        "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/login.sh" \
        "$SCRIPTS_DIR/login.sh" true

    install_asset "login-url script" "assets/scripts/login-url.sh" \
        "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/login-url.sh" \
        "$SCRIPTS_DIR/login-url.sh" true

    install_asset "cp-add-provider python script" "assets/scripts/cp-add-provider.py" \
        "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-add-provider.py" \
        "$SCRIPTS_DIR/cp-add-provider.py" true

