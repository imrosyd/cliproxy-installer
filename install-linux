def load_json(path: str):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}

cfg = load_json(droid_file)
existing = cfg.get("custom_models")
if not isinstance(existing, list):
    existing = []

def key(item):
    if not isinstance(item, dict):
        return None
    return (item.get("model"), item.get("base_url"), item.get("api_key"))

seen = set()
merged = []
for item in existing:
    k = key(item)
    if k and k not in seen:
        merged.append(item)
        seen.add(k)

added = 0
for item in new_custom:
    k = key(item)
    if k and k not in seen:
        merged.append(item)
        seen.add(k)
        added += 1

cfg["custom_models"] = merged
with open(droid_file, "w", encoding="utf-8") as f:
    json.dump(cfg, f, indent=2, ensure_ascii=False)
    f.write("\n")

print(f"Droid config: merged {len(new_custom)} models, added {added}, total {len(merged)}")
