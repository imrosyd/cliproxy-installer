# ── Install Claude Code ──
install_claude_code() {
    echo -e "${YELLOW}>>> Checking for Claude Code...${NC}"

    if command -v claude &> /dev/null; then
        echo -e "${GREEN}[OK] Claude Code is already installed.${NC}"
        claude --version 2>/dev/null || true
        return 0
    fi

    echo -e "${YELLOW}Claude Code not found. Installing...${NC}"

    # Check for npm
    if ! command -v npm &> /dev/null; then
        echo -e "${YELLOW}npm not found. Installing Node.js...${NC}"

        detect_distro
        case $DISTRO_ID in
            ubuntu|debian|kali|pop)
                # Use NodeSource for latest Node.js
                curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
                sudo apt-get install -y nodejs
                ;;
            fedora|centos|rhel)
                sudo dnf install -y nodejs npm || sudo yum install -y nodejs npm
                ;;
            arch|manjaro)
                sudo pacman -Syu --noconfirm nodejs npm
                ;;
            opensuse*|suse)
                sudo zypper install -y nodejs npm
                ;;
            *)
                echo -e "${RED}[!] Unsupported distro for auto-install.${NC}"
                echo "Please manually install 'nodejs' and 'npm' using your package manager."
                return 1
                ;;
        esac
    fi

    echo -e "${YELLOW}Installing Claude Code via npm...${NC}"
    sudo npm install -g @anthropic-ai/claude-code

    if command -v claude &> /dev/null; then
        echo -e "${GREEN}[OK] Claude Code installed successfully!${NC}"
        claude --version 2>/dev/null || true
    else
        echo -e "${RED}[Error] Failed to install Claude Code.${NC}"
        return 1
    fi
}

