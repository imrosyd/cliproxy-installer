    echo -e "  ${CYAN}cp-update${NC}      ${DIM}Update CLIProxy${NC}"
    echo -e "  ${CYAN}cp-claude${NC}      ${DIM}Launch Claude Code${NC}"
    echo -e "  ${CYAN}cp-opencode${NC}    ${DIM}Launch OpenCode${NC}"
