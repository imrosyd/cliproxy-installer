}

# ── Source Shell Configuration ──
source_shell_config() {
    echo -e "${YELLOW}Reloading shell configuration...${NC}"
    
    if [[ "$SHELL" == *"zsh"* ]]; then
        [ -f "$HOME/.zshrc" ] && source "$HOME/.zshrc" 2>/dev/null
    elif [[ "$SHELL" == *"fish"* ]]; then
        [ -f "$HOME/.config/fish/config.fish" ] && source "$HOME/.config/fish/config.fish" 2>/dev/null
    else
        [ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc" 2>/dev/null
    fi
    
    echo -e "${GREEN}[OK] Shell configuration loaded!${NC}"
}

setup_shortcuts() {
    SHELL_CONFIG="$HOME/.bashrc"
    if [[ "$SHELL" == *"zsh"* ]]; then
        SHELL_CONFIG="$HOME/.zshrc"
    elif [[ "$SHELL" == *"fish"* ]]; then
        # Fish uses different syntax - create fish config
        FISH_CONFIG="$HOME/.config/fish/config.fish"
        mkdir -p "$(dirname "$FISH_CONFIG")"

        echo -e "${YELLOW}Adding shortcuts for Fish shell to $FISH_CONFIG...${NC}"

        # Remove old aliases
        sed -i '/alias cp-login/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-start/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-stop/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-update/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-login-url/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-claude/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-db/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-opencode/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-droid/d' "$FISH_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-uninstall/d' "$FISH_CONFIG" 2>/dev/null || true

        # Add new aliases (Fish syntax)
        echo "" >> "$FISH_CONFIG"
        echo "# CLIProxy Shortcuts" >> "$FISH_CONFIG"
        echo "alias cp-login='$HOME/.cliproxyapi/scripts/login.sh'" >> "$FISH_CONFIG"
        echo "alias cp-login-url='$HOME/.cliproxyapi/scripts/login-url.sh'" >> "$FISH_CONFIG"
        echo "alias cp-start='$HOME/.cliproxyapi/scripts/start.sh'" >> "$FISH_CONFIG"
        echo "alias cp-stop='$HOME/.cliproxyapi/scripts/stop.sh'" >> "$FISH_CONFIG"
        echo "alias cp-update='curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/install-linux | bash -s -- -update'" >> "$FISH_CONFIG"
        echo "alias cp-claude='$HOME/.cliproxyapi/scripts/cp-claude.sh'" >> "$FISH_CONFIG"
        echo "alias cp-db='$HOME/.cliproxyapi/bin/cp-db'" >> "$FISH_CONFIG"
        echo "alias cp-opencode='$HOME/.cliproxyapi/scripts/cp-opencode.sh'" >> "$FISH_CONFIG"
        echo "alias cp-droid='$HOME/.cliproxyapi/scripts/cp-droid.sh'" >> "$FISH_CONFIG"
        echo "alias cp-uninstall='curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/uninstall | bash'" >> "$FISH_CONFIG"

        echo -e "${GREEN}[OK] Fish shortcuts added!${NC}"
        
        # Immediately source the config for Fish
        [ -f "$FISH_CONFIG" ] && source "$FISH_CONFIG" 2>/dev/null
        return
    fi

    echo -e "${YELLOW}Adding shortcuts to $SHELL_CONFIG...${NC}"

    # Remove all old aliases before re-adding (prevents duplicates across installs)
    sed -i '/alias cp-login/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-login-url/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-start/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-stop/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-update/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-claude/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-db/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-opencode/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-droid/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-add-provider/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/alias cp-uninstall/d' "$SHELL_CONFIG" 2>/dev/null || true
    sed -i '/# CLIProxy Shortcuts/d' "$SHELL_CONFIG" 2>/dev/null || true

    # Add new aliases
    echo "" >> "$SHELL_CONFIG"
    echo "# CLIProxy Shortcuts" >> "$SHELL_CONFIG"
    echo "alias cp-login=\"$HOME/.cliproxyapi/scripts/login.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-login-url=\"$HOME/.cliproxyapi/scripts/login-url.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-start=\"$HOME/.cliproxyapi/scripts/start.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-stop=\"$HOME/.cliproxyapi/scripts/stop.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-update=\"curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/install-linux | bash -s -- -update\"" >> "$SHELL_CONFIG"
    echo "alias cp-claude=\"$HOME/.cliproxyapi/scripts/cp-claude.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-db=\"$HOME/.cliproxyapi/bin/cp-db\"" >> "$SHELL_CONFIG"
    echo "alias cp-opencode=\"$HOME/.cliproxyapi/scripts/cp-opencode.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-kilo=\"$HOME/.cliproxyapi/scripts/cp-kilo.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-droid=\"$HOME/.cliproxyapi/scripts/cp-droid.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-uninstall=\"curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/uninstall | bash\"" >> "$SHELL_CONFIG"

    echo -e "${GREEN}[OK] Shortcuts added!${NC}"
    
    # Immediately source the config so aliases are available
    [ -f "$SHELL_CONFIG" ] && source "$SHELL_CONFIG" 2>/dev/null
}

clean_existing_configs() {
    echo -e "${YELLOW}>>> Cleaning existing configurations...${NC}"
    
    # 1. CLIProxy API (current directory)
    if [ -d "$HOME/.cliproxyapi" ]; then
        echo -e "  ${DIM}Removing ~/.cliproxyapi...${NC}"
        rm -rf "$HOME/.cliproxyapi"
    fi

    # 2. Legacy directory (old name before rename)
    if [ -d "$HOME/.cli-proxy-api" ]; then
        echo -e "  ${DIM}Removing legacy ~/.cli-proxy-api...${NC}"
        rm -rf "$HOME/.cli-proxy-api"
    fi

    # 3. Clean old binary locations (legacy: ~/bin/cliproxyapi)
    rm -f "$HOME/bin/cliproxyapi" 2>/dev/null
    rm -f "$HOME/bin/cliproxyapi-plus" 2>/dev/null
    rm -f "$HOME/bin/cp-db" 2>/dev/null
    rm -f "/usr/local/bin/cp-db" 2>/dev/null || true

    # 4. Clean old PATH entries for ~/bin if empty
    if [ -d "$HOME/bin" ] && [ -z "$(ls -A "$HOME/bin" 2>/dev/null)" ]; then
        rmdir "$HOME/bin" 2>/dev/null || true
    fi

    # Keep external tool configs to avoid wiping user setup.
    [ -f "$HOME/.config/opencode/opencode.json" ] && echo -e "  ${DIM}Preserving ~/.config/opencode/opencode.json${NC}"
    [ -f "$HOME/.claude/settings.json" ] && echo -e "  ${DIM}Preserving ~/.claude/settings.json${NC}"
    [ -f "$HOME/.factory/config.json" ] && echo -e "  ${DIM}Preserving ~/.factory/config.json${NC}"

    echo -e "${GREEN}[OK] All old configurations cleared.${NC}"
}

install_cliproxy() {
    IS_UPDATE="${1:-false}"

    if ! command -v go &> /dev/null; then
        echo -e "${RED}[Error] Go is not found!${NC}"
        echo "Please run option 1 to install dependencies first."
        exit 1
    fi

    # Keep existing auth/config on update so accounts remain logged in.
    if [ "$IS_UPDATE" = "true" ]; then
        echo -e "${CYAN}[i] Update mode: preserving existing config and auth files${NC}"
    else
        clean_existing_configs
    fi

    echo -e "${YELLOW}>>> Starting CLIProxy Installation...${NC}"

    CONFIG_DIR="$HOME/.cliproxyapi"
    BIN_DIR="$CONFIG_DIR/bin"
    SCRIPTS_DIR="$CONFIG_DIR/scripts"

    # Ensure bin is in PATH
    if [[ ":$PATH:" != *":$CONFIG_DIR/bin:"* ]] && [[ ":$PATH:" != *":$HOME/.cliproxyapi/bin:"* ]]; then
        echo 'export PATH="$HOME/.cliproxyapi/bin:$PATH"' >> "$HOME/.bashrc"
        [ -f "$HOME/.zshrc" ] && echo 'export PATH="$HOME/.cliproxyapi/bin:$PATH"' >> "$HOME/.zshrc"
        [ -f "$HOME/.config/fish/config.fish" ] && echo 'set -gx PATH $HOME/.cliproxyapi/bin $PATH' >> "$HOME/.config/fish/config.fish"
        echo -e "${YELLOW}[!] Added $HOME/.cliproxyapi/bin to PATH.${NC}"
    fi

    mkdir -p "$BIN_DIR"
    mkdir -p "$CONFIG_DIR"
    mkdir -p "$SCRIPTS_DIR"
    STATIC_DIR="$CONFIG_DIR/static"
    mkdir -p "$STATIC_DIR"

    # Copy enhanced dashboard
    echo -e "${YELLOW}Installing dashboard...${NC}"
    DASHBOARD_SRC="$(dirname "$0")/assets/static/dashboard.html"
    if [ -f "$DASHBOARD_SRC" ]; then
        cp "$DASHBOARD_SRC" "$STATIC_DIR/dashboard.html"
        echo -e "${GREEN}[OK] Dashboard installed from local assets${NC}"
    else
        # Fallback: try to download from GitHub
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/static/dashboard.html" -o "$STATIC_DIR/dashboard.html" 2>/dev/null; then
            echo -e "${GREEN}[OK] Dashboard downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install dashboard${NC}"
        fi
    fi

    # Install quota-fetcher.py
    echo -e "${YELLOW}Installing quota fetcher...${NC}"
    QUOTA_SRC="$(dirname "$0")/assets/scripts/quota-fetcher.py"
    if [ -f "$QUOTA_SRC" ]; then
        cp "$QUOTA_SRC" "$SCRIPTS_DIR/quota-fetcher.py"
        chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
        echo -e "${GREEN}[OK] Quota fetcher installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/quota-fetcher.py" -o "$SCRIPTS_DIR/quota-fetcher.py" 2>/dev/null; then
            chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
            echo -e "${GREEN}[OK] Quota fetcher downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install quota fetcher${NC}"
        fi
    fi

    # Install unified-server.py (serves static files + proxies API)
    echo -e "${YELLOW}Installing unified server...${NC}"
    UNIFIED_SRC="$(dirname "$0")/unified-server.py"
    if [ -f "$UNIFIED_SRC" ]; then
        cp "$UNIFIED_SRC" "$SCRIPTS_DIR/unified-server.py"
        chmod +x "$SCRIPTS_DIR/unified-server.py"
        echo -e "${GREEN}[OK] Unified server installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/unified-server.py" -o "$SCRIPTS_DIR/unified-server.py" 2>/dev/null; then
            chmod +x "$SCRIPTS_DIR/unified-server.py"
            echo -e "${GREEN}[OK] Unified server downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install unified server${NC}"
        fi
    fi

    # Install cp-db command
    echo -e "${YELLOW}Installing cp-db...${NC}"
    CPDB_SRC="$(dirname "$0")/assets/scripts/cp-db.sh"
    if [ -f "$CPDB_SRC" ]; then
        cp "$CPDB_SRC" "$BIN_DIR/cp-db"
        chmod +x "$BIN_DIR/cp-db"
        echo -e "${GREEN}[OK] cp-db installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-db.sh" -o "$BIN_DIR/cp-db" 2>/dev/null; then
            chmod +x "$BIN_DIR/cp-db"
            echo -e "${GREEN}[OK] cp-db downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install cp-db command${NC}"
        fi
    fi

    # Install cp-claude.sh
    echo -e "${YELLOW}Installing cp-claude...${NC}"
    CPCLOUD_SRC="$(dirname "$0")/assets/scripts/cp-claude.sh"
    if [ -f "$CPCLOUD_SRC" ]; then
        cp "$CPCLOUD_SRC" "$SCRIPTS_DIR/cp-claude.sh"
        echo -e "${GREEN}[OK] cp-claude installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-claude.sh" -o "$SCRIPTS_DIR/cp-claude.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] cp-claude downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install cp-claude${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-claude.sh" 2>/dev/null

    # Install cp-opencode.sh
    echo -e "${YELLOW}Installing cp-opencode...${NC}"
    CPOPENCODE_SRC="$(dirname \"$0\")/assets/scripts/cp-opencode.sh"
    if [ -f "$CPOPENCODE_SRC" ]; then
        cp "$CPOPENCODE_SRC" "$SCRIPTS_DIR/cp-opencode.sh"
        echo -e "${GREEN}[OK] cp-opencode installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-opencode.sh" -o "$SCRIPTS_DIR/cp-opencode.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] cp-opencode downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install cp-opencode${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-opencode.sh" 2>/dev/null

    # Install cp-kilo.sh
    echo -e "${YELLOW}Installing cp-kilo...${NC}"
    CPKILO_SRC="$(dirname \"$0\")/assets/scripts/cp-kilo.sh"
    if [ -f "$CPKILO_SRC" ]; then
        cp "$CPKILO_SRC" "$SCRIPTS_DIR/cp-kilo.sh"
        echo -e "${GREEN}[OK] cp-kilo installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-kilo.sh" -o "$SCRIPTS_DIR/cp-kilo.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] cp-kilo downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install cp-kilo${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-kilo.sh" 2>/dev/null

    # Install cp-droid.sh
    echo -e "${YELLOW}Installing cp-droid...${NC}"
    CPDROID_SRC="$(dirname "$0")/assets/scripts/cp-droid.sh"
    if [ -f "$CPDROID_SRC" ]; then
        cp "$CPDROID_SRC" "$SCRIPTS_DIR/cp-droid.sh"
        echo -e "${GREEN}[OK] cp-droid installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-droid.sh" -o "$SCRIPTS_DIR/cp-droid.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] cp-droid downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install cp-droid${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-droid.sh" 2>/dev/null


    # Clone & Build
    TEMP_DIR=$(mktemp -d)
    echo -e "${YELLOW}Cloning repository...${NC}"
    if ! git clone --depth 1 https://github.com/router-for-me/CLIProxyAPIPlus.git "$TEMP_DIR"; then
        echo -e "${RED}[Error] Failed to clone repository${NC}"
        rm -rf "$TEMP_DIR"
        exit 1
    fi

    echo -e "${YELLOW}Building binary...${NC}"
    cd "$TEMP_DIR"
    if ! go build -o cliproxyapi ./cmd/server; then
        echo -e "${RED}[Error] Failed to build binary${NC}"
        cd -
        rm -rf "$TEMP_DIR"
        exit 1
    fi
    mv -f cliproxyapi "$BIN_DIR/cliproxyapi"
    cd -
    rm -rf "$TEMP_DIR"

    echo -e "${GREEN}[OK] Binary built and installed successfully.${NC}"

    # Config
    # Only create if it doesn't exist, to preserve user settings on update
    if [ ! -f "$CONFIG_DIR/config.yaml" ]; then
        # Ask for optional baseURL and apiKey configuration
        echo ""
        echo -e "${YELLOW}${BOLD}  ── Optional: Custom Base URL & API Key ──${NC}"
        echo -e "  ${DIM}Configure a custom base URL and API key.${NC}"
        echo -e "  ${DIM}Press Enter to skip and use defaults (localhost:8317, sk-dummy)${NC}"
        echo ""
        
        read -p "Configure custom base URL and API key? (y/n): " configure_custom < /dev/tty
        
        CUSTOM_BASE_URL=""
        CUSTOM_API_KEY=""
        
        if [[ "$configure_custom" =~ ^[Yy]$ ]]; then
            echo ""
            read -p "Enter base URL (e.g., http://localhost:8317): " CUSTOM_BASE_URL < /dev/tty
            read -p "Enter API key (e.g., sk-your-key): " CUSTOM_API_KEY < /dev/tty
            
            # Use defaults if empty
            if [ -z "$CUSTOM_BASE_URL" ]; then
                CUSTOM_BASE_URL="http://localhost:8317"
            fi
            if [ -z "$CUSTOM_API_KEY" ]; then
                CUSTOM_API_KEY="sk-dummy"
            fi
            
            echo -e "${GREEN}[OK] Using custom configuration${NC}"
            echo -e \"  ${DIM}Base URL: $CUSTOM_BASE_URL${NC}\"
            echo -e \"  ${DIM}API Key: $CUSTOM_API_KEY${NC}\"
        else
            CUSTOM_BASE_URL=\"http://localhost:8317\"
            CUSTOM_API_KEY=\"sk-dummy\"
            echo -e \"${DIM}[i] Using default configuration${NC}\"
        fi
        
        cat > "$CONFIG_DIR/config.yaml" <<EOF
port: 8317
auth-dir: "$CONFIG_DIR"
api-keys:
  - "$CUSTOM_API_KEY"
remote-management:
  allow-remote: true
  secret-key: "$CUSTOM_API_KEY"
quota-exceeded:
  switch-project: true
  switch-preview-model: true
EOF
        echo -e "${GREEN}[OK] Created config.yaml${NC}"
        
        # Store base URL for later use if custom
        if [ "$CUSTOM_BASE_URL" != "http://localhost:8317" ]; then
            echo "$CUSTOM_BASE_URL" > "$CONFIG_DIR/.custom_base_url"
            echo "$CUSTOM_API_KEY" > "$CONFIG_DIR/.custom_api_key"
        fi
    fi

    # Helper Scripts
    cat > "$SCRIPTS_DIR/stop.sh" <<EOF
#!/bin/bash
# ── Stop CLIProxy server (unified server on 8317 + backend on 8316) ──

GREEN='\\033[0;32m'
YELLOW='\\033[1;33m'
NC='\\033[0m'

echo -e "\${YELLOW}Stopping CLIProxy server...\${NC}"
pkill -f "$HOME/.cliproxyapi/scripts/unified-server.py" || true
pkill -f "$HOME/.cliproxyapi/bin/cliproxyapi" || true
pkill -f "cliproxyapi.*\\.cliproxyapi/config.yaml" || true
echo -e "\${GREEN}[OK] Server stopped\${NC}"
EOF
    chmod +x "$SCRIPTS_DIR/stop.sh"

    cat > "$SCRIPTS_DIR/start.sh" <<EOF
#!/bin/bash

# ── Colors ──
GREEN='\\033[0;32m'
YELLOW='\\033[1;33m'
NC='\\033[0m'

echo -e "\${YELLOW}Stopping any existing CLIProxy instances...\${NC}"
if [ -f "$SCRIPTS_DIR/stop.sh" ]; then
    bash "$SCRIPTS_DIR/stop.sh" >/dev/null 2>&1
else
    pkill -f "$HOME/.cliproxyapi/scripts/unified-server.py" || true
    pkill -f "$HOME/.cliproxyapi/bin/cliproxyapi" || true
    pkill -f "cliproxyapi.*\\.cliproxyapi/config.yaml" || true
fi
echo -e "\${YELLOW}Starting CLIProxy on http://localhost:8317\${NC}"
if [ -f "$SCRIPTS_DIR/unified-server.py" ] && command -v python3 &>/dev/null; then
    python3 "$SCRIPTS_DIR/unified-server.py"
else
    echo -e "\${YELLOW}[!] Unified server not available, starting API-only mode\${NC}"
    "$BIN_DIR/cliproxyapi" --config "$CONFIG_DIR/config.yaml"
fi
EOF
    chmod +x "$SCRIPTS_DIR/start.sh"

    cat > "$SCRIPTS_DIR/login.sh" <<EOF
#!/bin/bash
BINARY="$BIN_DIR/cliproxyapi"
CONFIG="$CONFIG_DIR/config.yaml"

# ── Colors ──
GREEN='\\033[0;32m'
YELLOW='\\033[1;33m'
CYAN='\\033[0;36m'
BOLD='\\033[1m'
DIM='\\033[2m'
NC='\\033[0m'

clear
echo ""
echo -e "\${CYAN}\${BOLD}  ══  CLIProxy Login  ══\${NC}"
echo ""
echo -e "  \${BOLD}\${GREEN}1\${NC}  Antigravity"
echo -e "  \${BOLD}\${GREEN}2\${NC}  GitHub Copilot"
