import os
import sys
import json
import urllib.request
import yaml

CONFIG_PATH = os.path.expanduser("~/.cliproxyapi/config.yaml")

def print_header():
    print("\n  ══  CLIProxy - Add Custom Provider  ══\n")
    print("This will add an OpenAI-Compatible endpoint")
    print("seamlessly into your local configuration.\n")

def get_input(prompt, required=True):
    while True:
        val = input(prompt).strip()
        if val:
            return val
        if not required:
            return ""
        print("[!] This field is required.\n")

def fetch_models(base_url, api_key):
    print("\nFetching available models from API...")
    url = base_url.rstrip("/") + "/models"
    
    try:
        req = urllib.request.Request(
            url,
            headers={"Authorization": f"Bearer {api_key}"}
        )
        with urllib.request.urlopen(req, timeout=10) as response:
            data = json.loads(response.read().decode())
            models = data.get("data", [])
            return [m.get("id") for m in models if m.get("id")]
    except Exception as e:
        print(f"[ERROR] Failed to fetch models: {e}")
        return []

def main():
    print_header()
    provider_name = get_input("Provider Name (e.g., openai): ")
    base_url = get_input("Base URL (e.g., https://api.openai.com/v1): ")
    api_key = get_input("API Key (e.g., sk-...): ")
    
    models = fetch_models(base_url, api_key)
    
    if not models:
        print("\n[!] No models could be auto-fetched.")
        print("You can add models manually later in config.yaml.")
        models_to_add = []
    else:
        print(f"[OK] Fast-fetched {len(models)} models!")
        models_to_add = [{"name": m, "alias": m} for m in models]
    
    if not os.path.exists(CONFIG_PATH):
        print(f"\n[ERROR] CLIProxy Config not found at {CONFIG_PATH}")
        sys.exit(1)
        
    try:
        with open(CONFIG_PATH, 'r') as f:
            config = yaml.safe_load(f) or {}
    except Exception as e:
        print(f"\n[ERROR] Error reading config.yaml: {e}")
        sys.exit(1)
        
    if "openai-compatibility" not in config or not config["openai-compatibility"]:
        config["openai-compatibility"] = []
        
    for provider in config["openai-compatibility"]:
        if provider.get("name") == provider_name:
            print(f"\n[!] Provider '{provider_name}' already exists in config.yaml.")
            sys.exit(1)
            
    new_provider = {
        "name": provider_name,
        "base-url": base_url,
        "api-key-entries": [{"api-key": api_key}],
        "models": models_to_add
    }
    
    config["openai-compatibility"].append(new_provider)
    
    try:
        with open(CONFIG_PATH, 'w') as f:
            yaml.dump(config, f, default_flow_style=False, sort_keys=False)
    except Exception as e:
        print(f"\n[ERROR] Error saving config.yaml: {e}")
        sys.exit(1)
        
    print("\n[OK] Successfully added custom provider to config.yaml!")
    print("Please restart CLIProxy using `cp-start` to apply the changes.")

if __name__ == "__main__":
    main()
EOF

