                update_cliproxy
                ;;
            5)
                menu_cli_apps
                ;;
            6) 
                if [ -f "./uninstall" ]; then
                    bash ./uninstall
                else
                    echo -e "${YELLOW}Downloading uninstall script...${NC}"
                    curl -fsSL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/uninstall -o /tmp/uninstall.sh
                    bash /tmp/uninstall.sh
                fi
                echo -e "${GREEN}Uninstall complete. Goodbye!${NC}"
                exit 0
                ;;
            7)
                run_antigravity_manager
                ;;
            0) echo -e "${YELLOW}Goodbye!${NC}"; exit 0 ;;
            *) echo -e "${RED}Invalid choice.${NC}"; sleep 1 ;;
        esac
    done
}

uninstall_all() {
    echo -e "${YELLOW}Uninstalling CLIProxy + All CLI Apps...${NC}"
    echo ""
    
    read -p "Are you sure you want to uninstall EVERYTHING? (y/n): " confirm < /dev/tty
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Uninstall cancelled."
        return
    fi
    
    # Stop running services
    pkill -f "$HOME/.cliproxyapi/scripts/unified-server.py" 2>/dev/null || true
    pkill -f "$HOME/.cliproxyapi/bin/cliproxyapi" 2>/dev/null || true
    
    # Remove cron entries
    tmp=$(mktemp)
    if crontab -l 2>/dev/null > "$tmp"; then
        grep -v "$HOME/.cliproxyapi/scripts/quota-fetcher.py" "$tmp" > "$tmp.new" 2>/dev/null || true
        crontab "$tmp.new" 2>/dev/null || true
        rm -f "$tmp.new"
    fi
    rm -f "$tmp"
    
    # Remove CLIProxy directories
    rm -rf "$HOME/.cliproxyapi"
    rm -rf "$HOME/.cli-proxy-api"
    rm -f "$HOME/bin/cliproxyapi" 2>/dev/null
    rm -f "$HOME/bin/cp-db" 2>/dev/null
    
    # Remove aliases from shell config
    for config in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.config/fish/config.fish"; do
        if [ -f "$config" ]; then
            sed -i '/# CLIProxy Shortcuts/d' "$config" 2>/dev/null || true
            sed -i '/alias cp-/d' "$config" 2>/dev/null || true
        fi
    done
    
    # Uninstall CLI Apps
    if command -v npm >/dev/null 2>&1; then
        sudo npm uninstall -g @anthropic-ai/claude-code 2>/dev/null || npm uninstall -g @anthropic-ai/claude-code 2>/dev/null
        sudo npm uninstall -g opencode-ai 2>/dev/null || npm uninstall -g opencode-ai 2>/dev/null
        sudo npm uninstall -g @kilocode/cli 2>/dev/null || npm uninstall -g @kilocode/cli 2>/dev/null
    fi
    if command -v bun >/dev/null 2>&1; then
        sudo bun uninstall -g opencode-ai 2>/dev/null || bun uninstall -g opencode-ai 2>/dev/null
        sudo bun uninstall -g @kilocode/cli 2>/dev/null || bun uninstall -g @kilocode/cli 2>/dev/null
    fi
    rm -f /usr/local/bin/droid 2>/dev/null || sudo rm -f /usr/local/bin/droid 2>/dev/null
    rm -rf ~/.factory 2>/dev/null
    
    echo -e "${GREEN}[OK] Everything uninstalled successfully!${NC}"
}

update_cliproxy() {
    install_dependencies
    if [ -d "$HOME/.cliproxyapi" ]; then
        echo -e "${CYAN}[i] Updating CLIProxy (preserve config/auth)${NC}"
        install_cliproxy "true"
    else
        echo -e "${CYAN}[i] CLIProxy not found, installing fresh...${NC}"
        install_cliproxy
    fi
    update_claude_code || true
    auto_update_optional_tools || true
    echo -e "${GREEN}[OK] Update complete!${NC}"
}

