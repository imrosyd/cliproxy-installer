#!/bin/bash

# ==============================================================================
# CLIProxy Uninstaller
# Thoroughly removes CLIProxy and its components
# ==============================================================================

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

echo -e "${CYAN}========================================${NC}"
echo -e "${CYAN}       CLIProxy Thorough Uninstaller      ${NC}"
echo -e "${CYAN}========================================${NC}"
echo ""

# 1. Ask for confirmation
read -p "Are you sure you want to completely remove CLIProxy? (y/n): " confirm < /dev/tty
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Uninstallation cancelled."
    exit 0
fi

# 2. Stop running services
echo -e "${YELLOW}>>> Stopping CLIProxy services...${NC}"
pkill -f unified-server.py || true
pkill -f cliproxyapi-plus || true
echo -e "${GREEN}[OK] Services stopped.${NC}"

# 3. Remove Cron Job
echo -e "${YELLOW}>>> Removing Cron Job...${NC}"
crontab -l 2>/dev/null | grep -v "quota-fetcher.py" | crontab - 2>/dev/null
echo -e "${GREEN}[OK] Cron job removed.${NC}"

# 4. Remove directories and configs
echo -e "${YELLOW}>>> Removing installation directories and configs...${NC}"
rm -rf "$HOME/.cli-proxy-api"
rm -rf "$HOME/Scripts/claude-statusline"

# Remove OpenCode and Droid configs
rm -f "$HOME/.config/opencode/opencode.json" 2>/dev/null
rm -f "$HOME/.factory/config.json" 2>/dev/null

echo -e "${GREEN}[OK] Directories and configs removed.${NC}"

# 5. Remove binaries
echo -e "${YELLOW}>>> Removing binaries...${NC}"
rm -f "$HOME/bin/cliproxyapi-plus"
rm -f "$HOME/bin/cliproxyapi-plus.exe"
rm -f "$HOME/bin/cp-db"
echo -e "${GREEN}[OK] Binaries removed.${NC}"

# 6. Remove aliases from shell config
echo -e "${YELLOW}>>> Removing aliases from shell configuration...${NC}"
remove_aliases() {
    local config=$1
    if [ -f "$config" ]; then
        # Remove the block and specific aliases
        sed -i '/# CLIProxy Shortcuts/d' "$config" 2>/dev/null || sed -i '' '/# CLIProxy Shortcuts/d' "$config" 2>/dev/null
        sed -i '/alias cp-login/d' "$config" 2>/dev/null || sed -i '' '/alias cp-login/d' "$config" 2>/dev/null
        sed -i '/alias cp-login-url/d' "$config" 2>/dev/null || sed -i '' '/alias cp-login-url/d' "$config" 2>/dev/null
        sed -i '/alias cp-start/d' "$config" 2>/dev/null || sed -i '' '/alias cp-start/d' "$config" 2>/dev/null
        sed -i '/alias cp-update/d' "$config" 2>/dev/null || sed -i '' '/alias cp-update/d' "$config" 2>/dev/null
        sed -i '/alias cp-stop/d' "$config" 2>/dev/null || sed -i '' '/alias cp-stop/d' "$config" 2>/dev/null
        sed -i '/alias cp-claude/d' "$config" 2>/dev/null || sed -i '' '/alias cp-claude/d' "$config" 2>/dev/null
        sed -i '/alias cp-db/d' "$config" 2>/dev/null || sed -i '' '/alias cp-db/d' "$config" 2>/dev/null
        sed -i '/alias cp-opencode/d' "$config" 2>/dev/null || sed -i '' '/alias cp-opencode/d' "$config" 2>/dev/null
        sed -i '/alias cp-droid/d' "$config" 2>/dev/null || sed -i '' '/alias cp-droid/d' "$config" 2>/dev/null
        sed -i '/alias cp-add-provider/d' "$config" 2>/dev/null || sed -i '' '/alias cp-add-provider/d' "$config" 2>/dev/null
        sed -i '/alias cp-uninstall/d' "$config" 2>/dev/null || sed -i '' '/alias cp-uninstall/d' "$config" 2>/dev/null
        echo -e "${GREEN}[OK] Cleaned $config${NC}"
    fi
}

remove_aliases "$HOME/.bashrc"
remove_aliases "$HOME/.zshrc"

# 7. Check Claude Code settings
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
if [ -f "$CLAUDE_SETTINGS" ]; then
    echo -e "${YELLOW}>>> Checking Claude Code settings...${NC}"
    if command -v jq &> /dev/null; then
        # Remove statusLine config
        jq 'del(.statusLine)' "$CLAUDE_SETTINGS" > "$CLAUDE_SETTINGS.tmp" && mv "$CLAUDE_SETTINGS.tmp" "$CLAUDE_SETTINGS"
        echo -e "${GREEN}[OK] Removed statusLine from Claude Code settings.${NC}"
    else
        echo -e "${YELLOW}[!] jq not found, skipping Claude Code settings cleanup.${NC}"
    fi
fi

echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}   UNINSTALLATION COMPLETE!${NC}"
echo -e "${GREEN}========================================${NC}"
echo "Please restart your terminal or run 'source ~/.zshrc' / 'source ~/.bashrc'."
echo ""
