# Always refresh OpenCode config with latest models from CLIProxy
python3 - <<'PYSCRIPT' 2>/dev/null
import json, urllib.request, os

try:
    req = urllib.request.Request(
        "http://localhost:8317/v1/models",
        headers={"Authorization": "Bearer sk-dummy"}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        data = json.loads(response.read().decode())
        models = data.get("data", [])
except:
    models = []

if not models:
    exit(0)

opencode_models = {}
default_model = small_model = None

for m in models:
    model_id = m.get("id", "")
    owner = m.get("owned_by", "")
    display = model_id.replace("-", " ").title()

    # Determine context and output limits
    if any(x in model_id for x in ["claude", "opus", "sonnet"]):
        ctx, out = 200000, 16384
    elif any(x in model_id for x in ["gemini", "flash"]):
        ctx, out = 1000000, 65536
    else:
        ctx, out = 128000, 16384

    opencode_models[model_id] = {
        "name": display,
        "inputPrice": 0,
        "outputPrice": 0,
        "contextWindow": ctx,
        "maxOutput": out
    }

    # Auto-pick defaults (prefer opus/pro, then sonnet, then first available)
    if not default_model and any(x in model_id for x in ["opus", "pro"]):
        default_model = f"cliproxy/{model_id}"
    if not small_model and any(x in model_id for x in ["sonnet", "flash"]):
        small_model = f"cliproxy/{model_id}"

if not default_model and opencode_models:
    default_model = f"cliproxy/{list(opencode_models.keys())[0]}"
if not small_model and opencode_models:
    small_model = f"cliproxy/{list(opencode_models.keys())[-1]}"

config_path = os.path.expanduser("~/.config/opencode/opencode.json")
os.makedirs(os.path.dirname(config_path), exist_ok=True)

config = {
    "provider": {
        "cliproxy": {
            "name": "CLIProxy",
            "id": "cliproxy",
            "env": [],
            "options": {
                "baseURL": "http://localhost:8317/v1",
                "apiKey": "sk-dummy"
            },
            "models": opencode_models
        }
    },
    "model": default_model,
    "small_model": small_model
}

with open(config_path, "w") as f:
    json.dump(config, f, indent=2)

print(f"🔄 OpenCode model list refreshed ({len(opencode_models)} models available)")
PYSCRIPT

# Check if OpenCode is installed
if ! command -v opencode > /dev/null 2>&1; then
    echo "OpenCode not found. Installing..."

    if command -v bun > /dev/null 2>&1; then
        bun install -g opencode-ai@latest
    elif command -v npm > /dev/null 2>&1; then
        npm install -g opencode-ai@latest
    else
        echo "Error: Neither npm nor bun found."
        echo "Or try: curl -fsSL https://opencode.ai/install | bash"
        exit 1
    fi
fi

echo ""
echo "🚀 Launching OpenCode with CLIProxy..."
echo "   Proxy: $PROXY_URL"
echo ""

exec opencode "$@"
EOF
    chmod +x "$SCRIPTS_DIR/cp-opencode.sh"

    # Install cp-droid script
    if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-droid.sh" -o "$SCRIPTS_DIR/cp-droid.sh" 2>/dev/null; then
        chmod +x "$SCRIPTS_DIR/cp-droid.sh"
        echo -e "${GREEN}[OK] cp-droid installed to $SCRIPTS_DIR/cp-droid.sh${NC}"
    else
        echo -e "${YELLOW}[!] Could not download cp-droid.sh from GitHub${NC}"
    fi

    # Droid Config Injection - Fetch available models from API
    DROID_FILE="$HOME/.factory/config.json"
    mkdir -p "$(dirname "$DROID_FILE")"

    # Generate models dynamically from CLIProxy API
    echo -e "${YELLOW}Fetching available models from CLIProxy...${NC}"

    # Create Python script to fetch and format models
    python3 - <<'PYSCRIPT'
import json
import urllib.request
import os

try:
    # Try to fetch models from running CLIProxy server
    req = urllib.request.Request(
        "http://localhost:8317/v1/models",
        headers={"Authorization": "Bearer sk-dummy"}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        data = json.loads(response.read().decode())
        models = data.get("data", [])
except:
    # Fallback to empty - will be populated on first cp-db/cp-claude run
    models = []

# Model display name mapping
display_names = {
    "gemini-claude-opus-4-5-thinking": "Claude Opus 4.5 Thinking",
    "gemini-claude-sonnet-4-5-thinking": "Claude Sonnet 4.5 Thinking",
    "gemini-claude-sonnet-4-5": "Claude Sonnet 4.5",
    "gemini-3-pro-preview": "Gemini 3 Pro",
    "gemini-3-pro-image-preview": "Gemini 3 Pro Image",
    "gemini-2.5-flash": "Gemini 2.5 Flash",
    "gemini-2.5-flash-lite": "Gemini 2.5 Flash Lite",
    "gemini-3-flash": "Gemini 3 Flash",
    "gemini-2.5-computer-use-preview-10-2025": "Gemini Computer Use",
    "gpt-oss-120b-medium": "GPT-OSS 120B Medium",
    # Copilot models
    "claude-opus-4.5": "Claude Opus 4.5 [Copilot]",
    "claude-sonnet-4.5": "Claude Sonnet 4.5 [Copilot]",
    "gpt-5-mini": "GPT-5 Mini [Copilot]",
    "gpt-4.5": "GPT-4.5 [Copilot]",
    # Codex models
    "gpt-5.1-codex-max": "GPT-5.1 Codex Max [Codex]",
    # Kiro models
    "kiro-claude-opus-4.5": "Claude Opus 4.5 [Kiro]",
    "kiro-claude-sonnet-4.5": "Claude Sonnet 4.5 [Kiro]",
    "kiro-claude-sonnet-4": "Claude Sonnet 4 [Kiro]",
    "kiro-claude-haiku-4.5": "Claude Haiku 4.5 [Kiro]",
    # Qwen models
    "qwen3-coder-plus": "Qwen3 Coder Plus [Qwen]",
    # iFlow models
    "glm-4.6": "GLM 4.6 [iFlow]",
    # Gemini CLI models
    "gemini-2.5-pro": "Gemini 2.5 Pro [Gemini]",
}

# Provider prefix mapping for display
provider_tags = {
    "antigravity": "[Antigravity]",
    "copilot": "[Copilot]",
    "github-copilot": "[Copilot]",
    "codex": "[Codex]",
    "kiro": "[Kiro]",
    "qwen": "[Qwen]",
    "iflow": "[iFlow]",
    "gemini": "[Gemini]",
    "claude": "[Claude]",
}

custom_models = []
for m in models:
    model_id = m.get("id", "")
    owner = m.get("owned_by", "unknown")

    # Get display name
    if model_id in display_names:
        display = display_names[model_id]
    else:
        # Auto-generate display name
        display = model_id.replace("-", " ").title()

    # Add provider tag if not already in display name
    tag = provider_tags.get(owner, f"[{owner.title()}]")
    if tag not in display:
        display = f"{display} {tag}"

    custom_models.append({
        "model_display_name": display,
        "model": model_id,
        "base_url": "http://localhost:8317/v1",
        "api_key": "sk-dummy",
        "provider": "openai"
    })

# Write to temp file
output = {"custom_models": custom_models}
with open("/tmp/cliproxy_new_models.json", "w") as f:
    json.dump(output, f, indent=4)

print(f"Found {len(custom_models)} models from CLIProxy")
PYSCRIPT

    if [ ! -f "$DROID_FILE" ]; then
        cp "/tmp/cliproxy_new_models.json" "$DROID_FILE"
        echo -e "${GREEN}[OK] Droid config created.${NC}"
    else
        echo -e "${YELLOW}[!] config.json exists, checking for missing models...${NC}"

        MERGE_UTIL="/tmp/merge_config_$$.go"
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/merge-config.go" -o "$MERGE_UTIL"; then
            go run "$MERGE_UTIL" "$DROID_FILE" "/tmp/cliproxy_new_models.json"
            rm -f "$MERGE_UTIL"
        else
            echo -e "${RED}[Error] Failed to download config merger. Skipping model merge.${NC}"
        fi
    fi
    rm -f "/tmp/cliproxy_new_models.json"

    # Download quota-fetcher.py and setup cron
    echo -e "${YELLOW}Setting up quota fetcher...${NC}"
    if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/quota-fetcher.py" -o "$SCRIPTS_DIR/quota-fetcher.py" 2>/dev/null; then
        chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
        echo -e "${GREEN}[OK] Quota fetcher installed${NC}"

        # Setup cron job (every 10 minutes)
        CRON_CMD="*/10 * * * * /usr/bin/python3 $HOME/.cli-proxy-api/scripts/quota-fetcher.py >/dev/null 2>&1"
        if ! crontab -l 2>/dev/null | grep -q "quota-fetcher.py"; then
            (crontab -l 2>/dev/null; echo "$CRON_CMD") | crontab -
            echo -e "${GREEN}[OK] Cron job added (runs every 10 min)${NC}"
        fi
    fi

    setup_shortcuts

    # Skip optional installs if in update mode
    if [ "$SKIP_OPTIONAL" != "true" ]; then
        # Ask about optional Claude Statusline
        echo ""
        echo -e "${YELLOW}========================================${NC}"
        echo -e "${YELLOW}   Optional: Claude Statusline${NC}"
        echo -e "${YELLOW}========================================${NC}"
        echo "Claude Statusline displays AI model info, costs, git status,"
        echo "and development environment details in Claude Code."
        echo ""
        read -p "Install Claude Statusline? (y/n): " install_statusline < /dev/tty

        if [[ "$install_statusline" =~ ^[Yy]$ ]]; then
            install_claude_statusline
        fi

        # Ask about optional Superpowers
        echo ""
        echo -e "${YELLOW}========================================${NC}"
        echo -e "${YELLOW}   Optional: Superpowers${NC}"
        echo -e "${YELLOW}========================================${NC}"
        echo "Superpowers adds advanced workflow skills to Claude Code:"
        echo "  - Brainstorming & spec refinement"
        echo "  - Implementation planning"
        echo "  - Subagent-driven development"
        echo "  - Test-driven development enforcement"
        echo ""
        read -p "Install Superpowers? (y/n): " install_superpowers_choice < /dev/tty

        if [[ "$install_superpowers_choice" =~ ^[Yy]$ ]]; then
            install_superpowers
        fi

        # Ask about optional OpenCode
        echo ""
        echo -e "${YELLOW}========================================${NC}"
        echo -e "${YELLOW}   Optional: OpenCode (SST)${NC}"
        echo -e "${YELLOW}========================================${NC}"
        echo "OpenCode is a terminal AI coding agent by SST with:"
        echo "  - Built-in cost tracking"
        echo "  - MCP server support"
        echo "  - Multi-provider support (via CLIProxy)"
        echo ""
        read -p "Install OpenCode? (y/n): " install_opencode_choice < /dev/tty

        if [[ "$install_opencode_choice" =~ ^[Yy]$ ]]; then
            install_opencode
        fi

        # Optional: Factory.ai Droid
        echo ""
        echo -e "${YELLOW}========================================${NC}"
        echo -e "${YELLOW}   Optional: Factory.ai Droid${NC}"
        echo -e "${YELLOW}========================================${NC}"
        echo "Droid is a terminal AI coding agent by Factory.ai with:"
        echo "  - Multi-model support (via CLIProxy)"
        echo "  - Automated code review & enterprise workflows"
        echo "  - Deep codebase understanding"
        echo ""
        read -p "Install Droid? (y/n): " install_droid_choice < /dev/tty

        if [[ "$install_droid_choice" =~ ^[Yy]$ ]]; then
            install_droid
        fi
    fi

    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}  INSTALLATION SUCCESS!${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo "Available shortcuts:"
    echo -e "  1. Login:      ${CYAN}cp-login${NC}"
    echo -e "  2. Login URL:  ${CYAN}cp-login-url${NC}"
    echo -e "  3. Start:      ${CYAN}cp-start${NC}"
    echo -e "  4. Stop:       ${CYAN}cp-stop${NC}"
    echo -e "  5. Update:     ${CYAN}cp-update${NC}"
    echo -e "  6. Claude:     ${CYAN}cp-claude${NC}"
    echo -e "  7. OpenCode:   ${CYAN}cp-opencode${NC}"
    echo -e "  8. Droid:      ${CYAN}cp-droid${NC}"
    echo -e "  9. Dashboard:  ${CYAN}cp-db${NC}"
    echo -e "  10. Uninstall: ${CYAN}cp-uninstall${NC}"
    echo ""

    # Auto-restart shell to apply new aliases
    echo -e "${YELLOW}Restarting shell to apply changes...${NC}"
    sleep 1

    # Determine shell config and restart
    SHELL_CONFIG="$HOME/.bashrc"
    if [[ "$SHELL" == *"zsh"* ]]; then
        SHELL_CONFIG="$HOME/.zshrc"
    fi

    PLATFORM=$(detect_os)
    if [ "$PLATFORM" == "windows" ]; then
        # Windows Git Bash - source config and exec new shell
        echo "Reloading shell configuration..."
        source "$SHELL_CONFIG" 2>/dev/null
        exec "$SHELL"
    else
        # macOS & Linux - exec replaces current shell with fresh one
        exec "$SHELL"
    fi
}

# --- Main Execution ---
# Wrapped in main() to ensure all functions are defined before execution,
# especially when piped through curl | bash

main() {

if [[ "$1" == "-update" ]]; then
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}   CLIProxy Full Update${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo ""

    # 1. Update Claude Code (auto-detect: brew cask, brew formula, or npm)
    echo -e "${YELLOW}>>> Updating Claude Code...${NC}"
    CLAUDE_UPDATED=false
    CLAUDE_INSTALL_METHOD="unknown"

    # Auto-detect installation method
    if command -v claude &> /dev/null; then
        CLAUDE_PATH=$(which claude)

        # Check if symlink points to Homebrew Caskroom
        if [[ -L "$CLAUDE_PATH" ]]; then
            CLAUDE_REAL_PATH=$(readlink "$CLAUDE_PATH" 2>/dev/null || readlink -f "$CLAUDE_PATH" 2>/dev/null)
            if [[ "$CLAUDE_REAL_PATH" == *"/Caskroom/"* ]]; then
                CLAUDE_INSTALL_METHOD="brew-cask"
            elif [[ "$CLAUDE_REAL_PATH" == *"/Cellar/"* ]]; then
                CLAUDE_INSTALL_METHOD="brew-formula"
            fi
        fi

        # Fallback: check npm if not detected via brew
        if [ "$CLAUDE_INSTALL_METHOD" = "unknown" ] && command -v npm &> /dev/null; then
            if npm list -g @anthropic-ai/claude-code &> /dev/null 2>&1; then
                CLAUDE_INSTALL_METHOD="npm"
            fi
        fi

        # Fallback: check brew list directly
        if [ "$CLAUDE_INSTALL_METHOD" = "unknown" ] && command -v brew &> /dev/null; then
            if brew list --cask claude-code &> /dev/null 2>&1; then
                CLAUDE_INSTALL_METHOD="brew-cask"
            elif brew list claude-code &> /dev/null 2>&1; then
                CLAUDE_INSTALL_METHOD="brew-formula"
            fi
        fi
    fi

    # Update based on detected method
    case "$CLAUDE_INSTALL_METHOD" in
        "brew-cask")
            echo "Detected: Claude Code installed via Homebrew Cask"
            # Get current and latest version
            CURRENT_VER=$(claude --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
            LATEST_VER=$(brew info --cask claude-code 2>/dev/null | grep -oE '^==> claude-code: [0-9]+\.[0-9]+\.[0-9]+' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')

            if [ "$CURRENT_VER" = "$LATEST_VER" ]; then
                echo -e "${GREEN}[OK] Claude Code is already up to date (v$CURRENT_VER)${NC}"
            else
                echo "Updating from v$CURRENT_VER to v$LATEST_VER..."
                brew reinstall --cask claude-code
                echo -e "${GREEN}[OK] Claude Code updated to v$LATEST_VER (brew cask)${NC}"
            fi
            CLAUDE_UPDATED=true
            ;;
        "brew-formula")
            echo "Detected: Claude Code installed via Homebrew formula"
            if brew upgrade claude-code 2>&1 | tee /dev/stderr | grep -q "already installed"; then
                echo -e "${GREEN}[OK] Claude Code is already up to date${NC}"
            else
                echo -e "${GREEN}[OK] Claude Code updated (brew)${NC}"
            fi
            CLAUDE_UPDATED=true
            ;;
        "npm")
            echo "Detected: Claude Code installed via npm"
            npm update -g @anthropic-ai/claude-code
            echo -e "${GREEN}[OK] Claude Code updated (npm)${NC}"
            CLAUDE_UPDATED=true
            ;;
        *)
            if command -v claude &> /dev/null; then
                echo -e "${YELLOW}[!] Claude Code found but install method unknown${NC}"
                echo "    Path: $(which claude)"
                echo "    Please update manually via brew or npm"
            else
                echo -e "${YELLOW}[!] Claude Code not installed, skipping${NC}"
            fi
            ;;
    esac
    echo ""

    # 2. Update CLIProxy Core
    echo -e "${YELLOW}>>> Updating CLIProxy Core...${NC}"
    install_dependencies
    install_cliproxy "true"  # Skip optional prompts in update mode
    echo ""

    # 3. Update Claude Statusline (if installed)
    STATUSLINE_DIR="$HOME/Scripts/claude-statusline"
    if [ -d "$STATUSLINE_DIR" ]; then
        echo -e "${YELLOW}>>> Updating Claude Statusline...${NC}"
        if curl -fsSL "https://raw.githubusercontent.com/galpratama/claude-statusline/main/statusline-command.sh" -o "$STATUSLINE_DIR/statusline-command.sh"; then
            chmod +x "$STATUSLINE_DIR/statusline-command.sh"
            echo -e "${GREEN}[OK] statusline-command.sh updated${NC}"
        fi
        if curl -fsSL "https://raw.githubusercontent.com/galpratama/claude-statusline/main/statusline-config.json" -o "$STATUSLINE_DIR/statusline-config.json"; then
            echo -e "${GREEN}[OK] statusline-config.json updated${NC}"
        fi
        echo ""
    fi

    # 4. Update Dashboard and Scripts
    echo -e "${YELLOW}>>> Updating Dashboard...${NC}"
    STATIC_DIR="$HOME/.cli-proxy-api/static"
    SCRIPTS_DIR="$HOME/.cli-proxy-api/scripts"
    BIN_DIR="$HOME/bin"
    mkdir -p "$STATIC_DIR" "$SCRIPTS_DIR" "$BIN_DIR"
    if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/static/dashboard.html" -o "$STATIC_DIR/dashboard.html" 2>/dev/null; then
        echo -e "${GREEN}[OK] Dashboard updated${NC}"
    else
        echo -e "${YELLOW}[!] Could not update dashboard${NC}"
    fi
    if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/unified-server.py" -o "$SCRIPTS_DIR/unified-server.py" 2>/dev/null; then
        echo -e "${GREEN}[OK] Unified server updated${NC}"
    else
        echo -e "${YELLOW}[!] Could not update unified server${NC}"
    fi
    if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/quota-fetcher.py" -o "$SCRIPTS_DIR/quota-fetcher.py" 2>/dev/null; then
        chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
        echo -e "${GREEN}[OK] Quota fetcher script updated${NC}"

        # Setup cron job for quota fetcher (every 10 minutes)
        CRON_CMD="*/10 * * * * /usr/bin/python3 $HOME/.cli-proxy-api/scripts/quota-fetcher.py >/dev/null 2>&1"
        if ! crontab -l 2>/dev/null | grep -q "quota-fetcher.py"; then
            (crontab -l 2>/dev/null; echo "$CRON_CMD") | crontab -
            echo -e "${GREEN}[OK] Cron job added (runs every 10 min)${NC}"
        else
            echo -e "${CYAN}[i] Cron job already exists${NC}"
        fi
    fi

    # Update cp-db script
    PLATFORM=$(detect_os)
    if [ "$PLATFORM" == "macos" ]; then
        OPEN_CMD="open"
    elif [ "$PLATFORM" == "linux" ]; then
        OPEN_CMD="xdg-open"
    elif [ "$PLATFORM" == "windows" ]; then
        OPEN_CMD="start"
    fi

    cat > "$BIN_DIR/cp-db" <<CPDBEOF
#!/bin/bash

# CLIProxy Dashboard Launcher
TIMESTAMP=\$(date +%s)
DASHBOARD_URL="http://localhost:8317/dashboard.html?v=\$TIMESTAMP"
PORT=8317
QUOTA_FETCHER="\$HOME/.cli-proxy-api/scripts/quota-fetcher.py"

echo "🔮 CLIProxy Dashboard Launcher"
echo ""

# Portable port check: tries ss, then netstat, then lsof
check_port() {
    local port=\$1
    if command -v ss &>/dev/null; then
        ss -tlnp 2>/dev/null | grep -q ":\$port "
        return \$?
    fi
    if command -v netstat &>/dev/null; then
        netstat -tlnp 2>/dev/null | grep -q ":\$port "
        return \$?
    fi
    if command -v lsof &>/dev/null; then
        lsof -i "::\$port" -sTCP:LISTEN &>/dev/null
        return \$?
    fi
    return 1
}

# Check if server is already running
if check_port \$PORT; then
    echo "✅ Server already running on port \$PORT"
else
    echo "⚠️  Server not running, starting now..."

    CP_START_CMD=""
    if command -v cp-start >/dev/null 2>&1; then
        CP_START_CMD="cp-start"
    elif [ -x "\$HOME/.cli-proxy-api/scripts/start.sh" ]; then
        CP_START_CMD="\$HOME/.cli-proxy-api/scripts/start.sh"
    fi

    if [ -n "\$CP_START_CMD" ]; then
        "\$CP_START_CMD" >/dev/null 2>&1 &
        echo "⏳ Waiting for server to start..."

        for i in {1..10}; do
            sleep 1
            if check_port \$PORT; then
                echo "✅ Server started successfully"
                break
            fi
            if [ \$i -eq 10 ]; then
                echo "❌ Server failed to start. Please check logs."
                exit 1
            fi
        done
    else
        echo "❌ cp-start command not found. Please install CLIProxy first."
        exit 1
    fi
fi

# Run quota fetcher to update dashboard data
if [ -f "\$QUOTA_FETCHER" ] && command -v python3 >/dev/null 2>&1; then
    echo "🔄 Fetching quota data..."
    python3 "\$QUOTA_FETCHER" 2>/dev/null
    echo "✅ Quota data updated."
fi

# Setup cron job if not exists
CRON_CMD="*/10 * * * * /usr/bin/python3 \$HOME/.cli-proxy-api/scripts/quota-fetcher.py >/dev/null 2>&1"
if ! crontab -l 2>/dev/null | grep -q "quota-fetcher.py"; then
    (crontab -l 2>/dev/null; echo "\$CRON_CMD") | crontab - 2>/dev/null
    echo "⏰ Cron job added (auto-refresh every 10 min)"
fi

echo ""
echo "🌐 Opening dashboard: \$DASHBOARD_URL"
echo ""

$OPEN_CMD "\$DASHBOARD_URL" >/dev/null 2>&1
echo "✨ Dashboard opened successfully!"
CPDBEOF
    chmod +x "$BIN_DIR/cp-db"
    echo -e "${GREEN}[OK] cp-db script updated${NC}"
    echo ""

    # 5. Update Superpowers (if installed)
    if command -v claude &> /dev/null; then
        # Check if superpowers plugin is installed by trying to update it
        echo -e "${YELLOW}>>> Updating Superpowers plugin...${NC}"
        if claude -p "/plugin update superpowers" 2>/dev/null; then
            echo -e "${GREEN}[OK] Superpowers updated${NC}"
        else
            echo -e "${YELLOW}[!] Superpowers not installed or update failed, skipping${NC}"
        fi
        echo ""
    fi

    # 6. Update OpenCode (if installed)
    if command -v opencode &> /dev/null; then
        echo -e "${YELLOW}>>> Updating OpenCode...${NC}"
        if command -v bun &> /dev/null; then
            bun update -g opencode-ai 2>/dev/null && echo -e "${GREEN}[OK] OpenCode updated (bun)${NC}"
        elif command -v npm &> /dev/null; then
            npm update -g opencode-ai 2>/dev/null && echo -e "${GREEN}[OK] OpenCode updated (npm)${NC}"
        fi

        # Update OpenCode config
        configure_opencode
        echo ""
    fi

    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}   Full Update Complete!${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo "Updated components:"
    echo "  - Claude Code (npm/brew)"
    echo "  - CLIProxy Core (binary + scripts)"
    echo "  - Claude Statusline (if installed)"
    echo "  - Dashboard"
    echo "  - Superpowers plugin (if installed)"
    echo "  - OpenCode (if installed)"
    echo ""

    # Auto-restart shell to apply new aliases
    echo -e "${YELLOW}Restarting shell to apply changes...${NC}"
    echo ""
    echo -e "${GREEN}Update complete! Please run 'source ~/.zshrc' or open a new terminal.${NC}"
    exit 0
fi

# Exit if we somehow got here after update (failsafe)
if [[ "$1" == "-update" ]]; then
    exit 0
fi

# --- Main Menu ---

clear
echo -e "${CYAN}========================================${NC}"
echo -e "${CYAN}   CLIProxy Universal Installer Manager${NC}"
echo -e "${CYAN}========================================${NC}"
echo ""
echo "Detected Platform: $(detect_os)"
echo ""
echo "1. Install Dependencies (Git & Go)"
echo "2. Install / Update CLIProxy Core"
echo "3. FULL INSTALL (Recommended for first run)"
echo "4. Exit"
echo ""
read -p "Please select your choice (1-4): " choice < /dev/tty

case $choice in
    1) install_dependencies ;;
    2) install_cliproxy ;;
    3)
        install_dependencies
        install_cliproxy
        ;;
    4) exit 0 ;;
    *) echo "Invalid choice." ;;
esac

}

main "$@"
