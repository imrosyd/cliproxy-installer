#!/bin/bash

# ══════════════════════════════════════════════════════════════════════════════
# CLIProxy Universal Installer
# macOS, Linux, Windows (Git Bash)
# ══════════════════════════════════════════════════════════════════════════════

# ── Colors ──
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Helper Functions ──

detect_os() {
    OS="$(uname -s)"
    case "$OS" in
        Linux*)     echo "linux";;
        Darwin*)    echo "macos";;
        MINGW*|MSYS*|CYGWIN*) echo "windows";;
        *)          echo "unknown";;
    esac
}

check_brew() {
    if command -v brew &> /dev/null; then
        echo -e "${GREEN}[OK] Homebrew is installed.${NC}"
        return 0
    else
        return 1
    fi
}

install_brew() {
    echo -e "${YELLOW}Installing Homebrew...${NC}"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [[ -f "/opt/homebrew/bin/brew" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    if [[ -f "/usr/local/bin/brew" ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
}

install_dependencies() {
    PLATFORM=$(detect_os)
    
    if [ "$PLATFORM" == "macos" ]; then
        if ! check_brew; then
            echo -e "${RED}[Error] Homebrew is generally required for macOS setup to install Git/Go easily.${NC}"
            echo -e "${YELLOW}Attempting to install Homebrew...${NC}"
            install_brew
        fi
        
        echo -e "${YELLOW}Updating Homebrew...${NC}"
        brew update
        
        echo -e "${YELLOW}Checking Git...${NC}"
        brew install git || echo "Git already installed/updated."
        
        echo -e "${YELLOW}Checking Go...${NC}"
        brew install go || echo "Go already installed/updated."

        echo -e "${YELLOW}Checking Python3...${NC}"
        if ! command -v python3 &> /dev/null; then
            brew install python3
        else
            echo "Python3 already installed."
        fi
        pip3 install --quiet requests 2>/dev/null || python3 -m pip install --quiet requests 2>/dev/null

    elif [ "$PLATFORM" == "linux" ]; then
        echo -e "${YELLOW}Detected Linux. Installing dependencies...${NC}"
        if command -v apt-get &> /dev/null; then
            echo "Using apt-get..."
            sudo apt-get update
            sudo apt-get install -y git golang python3 python3-pip
            pip3 install --quiet requests 2>/dev/null || python3 -m pip install --quiet requests 2>/dev/null
        elif command -v dnf &> /dev/null; then
            echo "Using dnf..."
            sudo dnf install -y git golang python3 python3-pip
            pip3 install --quiet requests 2>/dev/null
        elif command -v pacman &> /dev/null; then
            echo "Using pacman..."
            sudo pacman -S --noconfirm git go python python-pip python-requests
        elif command -v zypper &> /dev/null; then
            echo "Using zypper..."
            sudo zypper install -y git go python3 python3-pip
            pip3 install --quiet requests 2>/dev/null
        elif command -v yum &> /dev/null; then
            echo "Using yum..."
            sudo yum install -y git golang python3 python3-pip
            pip3 install --quiet requests 2>/dev/null
        else
            echo -e "${YELLOW}[Warning] Could not detect package manager. Please ensure Git, Go, and Python3 are installed manually.${NC}"
        fi
    elif [ "$PLATFORM" == "windows" ]; then
        echo -e "${YELLOW}Detected Windows (Git Bash/MSYS). Checking dependencies...${NC}"
        
        if command -v git &> /dev/null; then
             echo -e "${GREEN}[OK] Git is installed.${NC}"
        else
             echo -e "${RED}[Error] Git not found.${NC}"
             echo "Please install Git for Windows: https://git-scm.com/download/win"
             exit 1
        fi

        if command -v go &> /dev/null; then
             echo -e "${GREEN}[OK] Go is installed.${NC}"
        else
             echo -e "${RED}[Error] Go not found.${NC}"
             echo "Please install Go for Windows: https://go.dev/dl/"
             echo "After installing, restart your terminal and try again."
             exit 1
        fi

        if command -v python3 &> /dev/null || command -v python &> /dev/null; then
             echo -e "${GREEN}[OK] Python is installed.${NC}"
             pip install --quiet requests 2>/dev/null || python -m pip install --quiet requests 2>/dev/null
        else
             echo -e "${YELLOW}[Warning] Python not found. Quota fetcher will not work.${NC}"
             echo "Please install Python: https://www.python.org/downloads/"
        fi
    else
        echo -e "${RED}[Error] Unknown operating system: $(uname -s)${NC}"
        exit 1
    fi
    
    echo -e "${GREEN}[OK] Dependencies ready.${NC}"
}

setup_shortcuts() {
    SHELL_CONFIG="$HOME/.bashrc"
    if [[ "$SHELL" == *"zsh"* ]]; then
        SHELL_CONFIG="$HOME/.zshrc"
    fi

    echo -e "${YELLOW}Adding shortcuts to $SHELL_CONFIG...${NC}"

    # Remove old aliases if they exist to prevent duplicates
    PLATFORM=$(detect_os)
    if [ "$PLATFORM" == "macos" ]; then
        sed -i '' '/alias cp-login/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-start/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-update/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-stop/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-claude/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-db/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-opencode/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-login-url/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '' '/alias cp-add-provider/d' "$SHELL_CONFIG" 2>/dev/null || true
    else
        # Linux & Windows (Git Bash has standard sed usually)
        sed -i '/alias cp-login/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-start/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-update/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-stop/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-claude/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-db/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-opencode/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-login-url/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-add-provider/d' "$SHELL_CONFIG" 2>/dev/null || true
        sed -i '/alias cp-uninstall/d' "$SHELL_CONFIG" 2>/dev/null || true
    fi

    # Remove old cp-db from /usr/local/bin if exists (legacy location)
    if [ -f "/usr/local/bin/cp-db" ]; then
        rm -f "/usr/local/bin/cp-db" 2>/dev/null || sudo rm -f "/usr/local/bin/cp-db" 2>/dev/null || true
    fi

    # Add new aliases
    echo "" >> "$SHELL_CONFIG"
    echo "# CLIProxy Shortcuts" >> "$SHELL_CONFIG"
    echo "alias cp-login=\"$HOME/.cliproxyapi/scripts/login.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-login-url=\"$HOME/.cliproxyapi/scripts/login-url.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-start=\"$HOME/.cliproxyapi/scripts/start.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-update=\"curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/install | bash -s -- -update\"" >> "$SHELL_CONFIG"
    echo "alias cp-stop=\"$HOME/.cliproxyapi/scripts/stop.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-claude=\"$HOME/.cliproxyapi/scripts/cp-claude.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-db=\"$HOME/.cliproxyapi/bin/cp-db\"" >> "$SHELL_CONFIG"
    echo "alias cp-opencode=\"$HOME/.cliproxyapi/scripts/cp-opencode.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-droid=\"$HOME/.cliproxyapi/scripts/cp-droid.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-add-provider=\"$HOME/.cliproxyapi/scripts/cp-add-provider.sh\"" >> "$SHELL_CONFIG"
    echo "alias cp-uninstall=\"curl -sL https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/uninstall | bash\"" >> "$SHELL_CONFIG"

    echo -e "${GREEN}[OK] Shortcuts added.${NC}"
}

clean_existing_configs() {
    PRESERVE_AUTH="${1:-false}"
    
    echo -e "${YELLOW}>>> Cleaning existing configurations to ensure a fresh start...${NC}"
    
    # 1. CLIProxy API
    if [ -d "$HOME/.cliproxyapi" ]; then
        if [ "$PRESERVE_AUTH" = "true" ]; then
            # Backup authentication files before cleaning
            echo "Preserving authentication files..."
            TEMP_AUTH_BACKUP="/tmp/cliproxy-auth-backup-$$"
            mkdir -p "$TEMP_AUTH_BACKUP"
            
            # Backup all auth-related files and directories
            if [ -d "$HOME/.cliproxyapi/auth" ]; then
                cp -r "$HOME/.cliproxyapi/auth" "$TEMP_AUTH_BACKUP/" 2>/dev/null || true
            fi
            if [ -f "$HOME/.cliproxyapi/config.yaml" ]; then
                cp "$HOME/.cliproxyapi/config.yaml" "$TEMP_AUTH_BACKUP/" 2>/dev/null || true
            fi
            if [ -d "$HOME/.cliproxyapi/logs" ]; then
                cp -r "$HOME/.cliproxyapi/logs" "$TEMP_AUTH_BACKUP/" 2>/dev/null || true
            fi
            
            # Remove old installation
            echo "Removing ~/.cliproxyapi (preserving auth)..."
            rm -rf "$HOME/.cliproxyapi"
            
            # Will be restored after installation
        else
            echo "Removing ~/.cliproxyapi..."
            rm -rf "$HOME/.cliproxyapi"
        fi
    fi

    # Keep external tool configs to avoid wiping user setup.
    [ -f "$HOME/.config/opencode/opencode.json" ] && echo "Preserving ~/.config/opencode/opencode.json"
    [ -f "$HOME/.claude/settings.json" ] && echo "Preserving ~/.claude/settings.json"
    [ -f "$HOME/.factory/config.json" ] && echo "Preserving ~/.factory/config.json"

    echo -e "${GREEN}[OK] All old configurations cleared.${NC}"
}

restore_auth_files() {
    TEMP_AUTH_BACKUP="/tmp/cliproxy-auth-backup-$$"
    
    if [ -d "$TEMP_AUTH_BACKUP" ]; then
        echo -e "${YELLOW}>>> Restoring authentication files...${NC}"
        
        # Restore auth directory
        if [ -d "$TEMP_AUTH_BACKUP/auth" ]; then
            cp -r "$TEMP_AUTH_BACKUP/auth" "$HOME/.cliproxyapi/" 2>/dev/null || true
            echo -e "${GREEN}[OK] Auth files restored${NC}"
        fi
        
        # Restore config.yaml if it existed
        if [ -f "$TEMP_AUTH_BACKUP/config.yaml" ]; then
            cp "$TEMP_AUTH_BACKUP/config.yaml" "$HOME/.cliproxyapi/" 2>/dev/null || true
            echo -e "${GREEN}[OK] Config file restored${NC}"
        fi
        
        # Restore logs directory
        if [ -d "$TEMP_AUTH_BACKUP/logs" ]; then
            cp -r "$TEMP_AUTH_BACKUP/logs" "$HOME/.cliproxyapi/" 2>/dev/null || true
            echo -e "${GREEN}[OK] Logs restored${NC}"
        fi
        
        # Cleanup temp backup
        rm -rf "$TEMP_AUTH_BACKUP"
        echo -e "${GREEN}[OK] Authentication files restored successfully${NC}"
    fi
}

install_claude_statusline() {
    echo -e "${YELLOW}>>> Installing Claude Statusline...${NC}"
    
    PLATFORM=$(detect_os)
    STATUSLINE_DIR="$HOME/Scripts/claude-statusline"
    CLAUDE_SETTINGS="$HOME/.claude/settings.json"
    
    # Check for jq dependency
    if ! command -v jq &> /dev/null; then
        echo -e "${YELLOW}[!] jq is required for Claude Statusline${NC}"
        
        if [ "$PLATFORM" == "macos" ]; then
            echo "Installing jq via Homebrew..."
            brew install jq
        elif [ "$PLATFORM" == "linux" ]; then
            echo "Installing jq..."
            if command -v apt-get &> /dev/null; then
                sudo apt-get install -y jq
            elif command -v dnf &> /dev/null; then
                sudo dnf install -y jq
            elif command -v pacman &> /dev/null; then
                sudo pacman -S --noconfirm jq
            elif command -v yum &> /dev/null; then
                sudo yum install -y jq
            else
                echo -e "${RED}[Error] Could not install jq. Please install it manually.${NC}"
                return 1
            fi
        elif [ "$PLATFORM" == "windows" ]; then
            echo -e "${YELLOW}Please install jq manually:${NC}"
            echo "  - Using Chocolatey: choco install jq"
            echo "  - Using Scoop: scoop install jq"
            echo "  - Or download from: https://jqlang.github.io/jq/download/"
            return 1
        fi
    fi
    
    # Create directory
    mkdir -p "$STATUSLINE_DIR"
    
    # Download statusline files from GitHub
    echo "Downloading statusline script..."
    if curl -fsSL "https://raw.githubusercontent.com/galpratama/claude-statusline/main/statusline-command.sh" -o "$STATUSLINE_DIR/statusline-command.sh"; then
        chmod +x "$STATUSLINE_DIR/statusline-command.sh"
        echo -e "${GREEN}[OK] statusline-command.sh downloaded${NC}"
    else
        echo -e "${RED}[Error] Failed to download statusline-command.sh${NC}"
        return 1
    fi
    
    echo "Downloading statusline config..."
    if curl -fsSL "https://raw.githubusercontent.com/galpratama/claude-statusline/main/statusline-config.json" -o "$STATUSLINE_DIR/statusline-config.json"; then
        echo -e "${GREEN}[OK] statusline-config.json downloaded${NC}"
    else
        echo -e "${RED}[Error] Failed to download statusline-config.json${NC}"
        return 1
    fi
    
    # Set permissions
    chmod +x "$STATUSLINE_DIR/statusline-command.sh"
    
    # Configure Claude Code settings
    mkdir -p "$HOME/.claude"
    
    if [ -f "$CLAUDE_SETTINGS" ]; then
        # Backup existing settings
        cp "$CLAUDE_SETTINGS" "$CLAUDE_SETTINGS.backup"
        echo -e "${YELLOW}[!] Backed up existing settings.json${NC}"
        
        # Merge statusLine config
        if jq '. + {"statusLine": {"command": "/bin/bash $HOME/Scripts/claude-statusline/statusline-command.sh", "type": "command"}}' \
            "$CLAUDE_SETTINGS" > "$CLAUDE_SETTINGS.tmp" 2>/dev/null; then
            mv "$CLAUDE_SETTINGS.tmp" "$CLAUDE_SETTINGS"
            echo -e "${GREEN}[OK] Updated settings.json with statusLine config${NC}"
        else
            echo -e "${RED}[Error] Failed to update settings.json${NC}"
            rm -f "$CLAUDE_SETTINGS.tmp"
            return 1
        fi
    else
        # Create new settings file
        cat > "$CLAUDE_SETTINGS" <<'EOF'
{
  "statusLine": {
    "command": "/bin/bash $HOME/Scripts/claude-statusline/statusline-command.sh",
    "type": "command"
  }
}
EOF
        echo -e "${GREEN}[OK] Created settings.json with statusLine config${NC}"
    fi
    
    # Test the statusline
    echo "Testing statusline..."
    if bash "$STATUSLINE_DIR/statusline-command.sh" < /dev/null 2>/dev/null; then
        echo -e "${GREEN}[OK] Statusline script works!${NC}"
    else
        echo -e "${YELLOW}[!] Statusline test had issues (may need jq)${NC}"
    fi
    
    echo -e "${GREEN}[OK] Claude Statusline installed!${NC}"
    echo "    Restart Claude Code to see the statusline."
}

install_droid() {
    echo -e "${YELLOW}>>> Installing Factory.ai Droid...${NC}"

    if command -v droid > /dev/null 2>&1; then
        echo -e "${YELLOW}[!] Droid already installed. Updating...${NC}"
        curl -fsSL https://app.factory.ai/cli | sh
        echo -e "${GREEN}[OK] Droid updated!${NC}"
    else
        echo "Downloading and installing Factory.ai Droid..."
        if curl -fsSL https://app.factory.ai/cli | sh; then
            echo -e "${GREEN}[OK] Droid installed successfully!${NC}"
        else
            echo -e "${RED}[Error] Failed to install Droid.${NC}"
            echo "   Try manually: curl -fsSL https://app.factory.ai/cli | sh"
            return 1
        fi
    fi

    echo -e "${GREEN}[OK] Droid is ready!${NC}"
    echo "    Run in your project: droid"
}

install_opencode() {
    echo -e "${YELLOW}>>> Installing OpenCode...${NC}"

    # Check if npm or bun is available
    PKG_MANAGER=""
    if command -v bun &> /dev/null; then
        PKG_MANAGER="bun"
    elif command -v npm &> /dev/null; then
        PKG_MANAGER="npm"
    else
        echo -e "${RED}[Error] Neither npm nor bun found.${NC}"
        echo "Please install Node.js (npm) or Bun first:"
        echo "  - Node.js: https://nodejs.org/"
        echo "  - Bun: https://bun.sh/"
        echo ""
        echo "Or use the official install script:"
        echo "  curl -fsSL https://opencode.ai/install | bash"
        return 1
    fi

    echo "Using $PKG_MANAGER to install OpenCode..."

    if [ "$PKG_MANAGER" == "bun" ]; then
        bun install -g opencode-ai@latest
    else
        npm install -g opencode-ai@latest
    fi

    if ! command -v opencode &> /dev/null; then
        echo -e "${RED}[Error] OpenCode installation failed.${NC}"
        echo "Try the official install script:"
        echo "  curl -fsSL https://opencode.ai/install | bash"
        return 1
    fi

    echo -e "${GREEN}[OK] OpenCode installed successfully${NC}"

    # Configure OpenCode for CLIProxy
    configure_opencode

    echo -e "${GREEN}[OK] OpenCode is ready!${NC}"
    echo "    Run: cp-opencode"
}

configure_opencode() {
    echo -e "${YELLOW}Configuring OpenCode for CLIProxy...${NC}"

    # OpenCode config location: ~/.config/opencode/opencode.json
    OPENCODE_CONFIG_DIR="$HOME/.config/opencode"
    OPENCODE_CONFIG="$OPENCODE_CONFIG_DIR/opencode.json"

    mkdir -p "$OPENCODE_CONFIG_DIR"

    # Only create config if it doesn't exist (preserve user's existing config)
    if [ ! -f "$OPENCODE_CONFIG" ]; then
        echo "Fetching available models for OpenCode..."

        # Generate OpenCode config dynamically from CLIProxy API
        python3 - <<'PYSCRIPT'
import json
import urllib.request
import os

try:
    req = urllib.request.Request(
        "http://localhost:8317/v1/models",
        headers={"Authorization": "Bearer sk-dummy"}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        data = json.loads(response.read().decode())
        models = data.get("data", [])
except:
    models = []

# Model display name and context window mapping
model_info = {
    "gemini-claude-opus-4-5-thinking": {"name": "Claude Opus 4.5 Thinking", "contextWindow": 200000, "maxOutput": 16384},
    "gemini-claude-sonnet-4-5-thinking": {"name": "Claude Sonnet 4.5 Thinking", "contextWindow": 200000, "maxOutput": 16384},
    "gemini-claude-sonnet-4-5": {"name": "Claude Sonnet 4.5", "contextWindow": 200000, "maxOutput": 16384},
    "gemini-3-pro-preview": {"name": "Gemini 3 Pro", "contextWindow": 1000000, "maxOutput": 65536},
    "gemini-3-pro-image-preview": {"name": "Gemini 3 Pro Image", "contextWindow": 1000000, "maxOutput": 65536},
    "gemini-2.5-flash": {"name": "Gemini 2.5 Flash", "contextWindow": 1000000, "maxOutput": 65536},
    "gemini-2.5-flash-lite": {"name": "Gemini 2.5 Flash Lite", "contextWindow": 1000000, "maxOutput": 65536},
    "gemini-3-flash": {"name": "Gemini 3 Flash", "contextWindow": 1000000, "maxOutput": 65536},
    "gpt-oss-120b-medium": {"name": "GPT-OSS 120B Medium", "contextWindow": 128000, "maxOutput": 16384},
}

opencode_models = {}
default_model = None
small_model = None

for m in models:
    model_id = m.get("id", "")

    if model_id in model_info:
        info = model_info[model_id]
    else:
        info = {"name": model_id.replace("-", " ").title(), "contextWindow": 128000, "maxOutput": 16384}

    opencode_models[model_id] = {
        "name": info["name"],
        "inputPrice": 0,
        "outputPrice": 0,
        "contextWindow": info["contextWindow"],
        "maxOutput": info["maxOutput"]
    }

    # Set defaults based on model availability
    if model_id == "gemini-claude-opus-4-5-thinking":
        default_model = f"cliproxy/{model_id}"
    elif model_id == "gemini-claude-sonnet-4-5" and not small_model:
        small_model = f"cliproxy/{model_id}"

# Fallback defaults
if not default_model and opencode_models:
    default_model = f"cliproxy/{list(opencode_models.keys())[0]}"
if not small_model and opencode_models:
    small_model = f"cliproxy/{list(opencode_models.keys())[-1]}"

config = {
    "provider": {
        "cliproxy": {
            "name": "CLIProxy",
            "id": "cliproxy",
            "env": [],
            "options": {
                "baseURL": "http://localhost:8317/v1",
                "apiKey": "sk-dummy"
            },
            "models": opencode_models
        }
    },
    "model": default_model or "cliproxy/gemini-claude-opus-4-5-thinking",
    "small_model": small_model or "cliproxy/gemini-claude-sonnet-4-5"
}

config_path = os.path.expanduser("~/.config/opencode/opencode.json")
os.makedirs(os.path.dirname(config_path), exist_ok=True)
with open(config_path, "w") as f:
    json.dump(config, f, indent=2)

print(f"OpenCode configured with {len(opencode_models)} models")
PYSCRIPT
        echo -e "${GREEN}[OK] OpenCode configured at $OPENCODE_CONFIG${NC}"
    else
        echo -e "${YELLOW}[!] OpenCode config exists, preserving user settings${NC}"
        echo "    Location: $OPENCODE_CONFIG"
    fi
}

install_superpowers() {
    echo -e "${YELLOW}>>> Installing Superpowers for Claude Code...${NC}"

    # Check if claude command exists
    if ! command -v claude &> /dev/null; then
        echo -e "${RED}[Error] Claude Code not found. Please install Claude Code first.${NC}"
        return 1
    fi

    echo "This will run Claude Code to install the Superpowers plugin."
    echo ""
    echo "After Claude Code opens, the installer will automatically run:"
    echo "  1. /plugin marketplace add obra/superpowers-marketplace"
    echo "  2. /plugin install superpowers@superpowers-marketplace"
    echo ""

    # Create a temporary script that Claude will execute
    SUPERPOWERS_INSTALL_CMD='echo "Installing Superpowers plugin..." && claude -p "/plugin marketplace add obra/superpowers-marketplace" && sleep 2 && claude -p "/plugin install superpowers@superpowers-marketplace"'

    # Run the plugin commands
    echo "Running: /plugin marketplace add obra/superpowers-marketplace"
    if claude -p "/plugin marketplace add obra/superpowers-marketplace" 2>/dev/null; then
        echo -e "${GREEN}[OK] Marketplace added${NC}"
    else
        echo -e "${YELLOW}[!] Marketplace may already be added or command failed${NC}"
    fi

    sleep 1

    echo "Running: /plugin install superpowers@superpowers-marketplace"
    if claude -p "/plugin install superpowers@superpowers-marketplace" 2>/dev/null; then
        echo -e "${GREEN}[OK] Superpowers plugin installed${NC}"
    else
        echo -e "${YELLOW}[!] Plugin install may have failed. Try manually:${NC}"
        echo "    claude"
        echo "    /plugin marketplace add obra/superpowers-marketplace"
        echo "    /plugin install superpowers@superpowers-marketplace"
        return 1
    fi

    echo ""
    echo -e "${GREEN}[OK] Superpowers installed!${NC}"
    echo "    Verify with: claude, then type /help"
    echo "    You should see /superpowers:brainstorm, /superpowers:write-plan, etc."
}

auto_update_claude_code() {
    echo -e "${YELLOW}>>> Updating Claude Code...${NC}"

    if command -v npm &> /dev/null; then
        if command -v claude &> /dev/null; then
            npm update -g @anthropic-ai/claude-code 2>/dev/null || true
        else
            npm install -g @anthropic-ai/claude-code 2>/dev/null || true
        fi
        if command -v claude &> /dev/null; then
            echo -e "${GREEN}[OK] Claude Code updated via npm${NC}"
            return 0
        fi
    fi

    if command -v brew &> /dev/null; then
        if brew list --cask claude-code &> /dev/null 2>&1; then
            brew reinstall --cask claude-code 2>/dev/null || true
        else
            brew install --cask claude-code 2>/dev/null || true
        fi
        if command -v claude &> /dev/null; then
            echo -e "${GREEN}[OK] Claude Code updated via Homebrew${NC}"
            return 0
        fi
    fi

    if command -v claude &> /dev/null; then
        echo -e "${YELLOW}[!] Claude Code found, skipped installer-specific update${NC}"
    else
        echo -e "${YELLOW}[!] Claude Code update skipped (npm/brew not found)${NC}"
    fi
}

install_cliproxy() {
    SKIP_OPTIONAL="${1:-false}"
    IS_UPDATE="${2:-false}"
    PLATFORM=$(detect_os)
    INSTALL_STATUSLINE="n"
    INSTALL_SUPERPOWERS="n"
    INSTALL_OPENCODE="n"
    INSTALL_DROID="n"
    CONFIGURE_CUSTOM="n"
    CUSTOM_BASE_URL="http://localhost:8317"
    CUSTOM_API_KEY="sk-dummy"
    
    if ! command -v go &> /dev/null; then
        echo -e "${RED}[Error] Go is not found!${NC}"
        echo "Please install dependencies first."
        exit 1
    fi

    # Collect all interactive install options at the beginning.
    if [ "$SKIP_OPTIONAL" != "true" ] && [ "$IS_UPDATE" != "true" ]; then
        echo ""
        echo -e "${YELLOW}${BOLD}  ── Install Options ──────────────────────────────${NC}"
        echo ""

        echo -e "${YELLOW}${BOLD}  ── Optional: Custom Base URL & API Key ──────────${NC}"
        echo "You can configure a custom base URL and API key now."
        echo "Press Enter to skip and use defaults (localhost:8317, sk-dummy)."
        echo ""
        read -p "Configure custom base URL and API key? (y/n): " CONFIGURE_CUSTOM < /dev/tty
        if [[ "$CONFIGURE_CUSTOM" =~ ^[Yy]$ ]]; then
            echo ""
            read -p "Enter base URL (e.g., http://localhost:8317): " CUSTOM_BASE_URL < /dev/tty
            read -p "Enter API key (e.g., sk-your-key): " CUSTOM_API_KEY < /dev/tty
            [ -z "$CUSTOM_BASE_URL" ] && CUSTOM_BASE_URL="http://localhost:8317"
            [ -z "$CUSTOM_API_KEY" ] && CUSTOM_API_KEY="sk-dummy"
        fi

        echo ""
        echo -e "${YELLOW}${BOLD}  ── Optional Components ──────────────────────────${NC}"
        read -p "Install Claude Statusline? (y/n): " INSTALL_STATUSLINE < /dev/tty
        read -p "Install Superpowers? (y/n): " INSTALL_SUPERPOWERS < /dev/tty
        read -p "Install OpenCode? (y/n): " INSTALL_OPENCODE < /dev/tty
        read -p "Install Droid? (y/n): " INSTALL_DROID < /dev/tty
        echo ""
    fi

    # Never wipe config/auth during update to keep logged-in accounts intact.
    if [ "$IS_UPDATE" = "true" ]; then
        echo -e "${CYAN}[i] Update mode: preserving existing config and auth files${NC}"
    else
        clean_existing_configs "false" # Fresh install, clean everything
    fi

    echo -e "${YELLOW}>>> Starting CLIProxy Installation...${NC}"

    CONFIG_DIR="$HOME/.cliproxyapi"
    BIN_DIR="$CONFIG_DIR/bin"
    SCRIPTS_DIR="$CONFIG_DIR/scripts"

    mkdir -p "$BIN_DIR"
    mkdir -p "$CONFIG_DIR"
    mkdir -p "$SCRIPTS_DIR"
    STATIC_DIR="$CONFIG_DIR/static"
    mkdir -p "$STATIC_DIR"

    # Copy enhanced dashboard
    echo "Installing enhanced dashboard..."
    DASHBOARD_SRC="$(dirname "$0")/assets/static/dashboard.html"
    if [ -f "$DASHBOARD_SRC" ]; then
        cp "$DASHBOARD_SRC" "$STATIC_DIR/dashboard.html"
        echo -e "${GREEN}[OK] Dashboard installed from local assets${NC}"
    else
        # Fallback to download
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/static/dashboard.html" -o "$STATIC_DIR/dashboard.html" 2>/dev/null; then
            echo -e "${GREEN}[OK] Dashboard downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install dashboard${NC}"
        fi
    fi

    # Install quota-fetcher.py
    echo "Installing quota fetcher daemon..."
    QUOTA_SRC="$(dirname "$0")/assets/scripts/quota-fetcher.py"
    if [ -f "$QUOTA_SRC" ]; then
        cp "$QUOTA_SRC" "$SCRIPTS_DIR/quota-fetcher.py"
        chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
        echo -e "${GREEN}[OK] Quota fetcher installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/quota-fetcher.py" -o "$SCRIPTS_DIR/quota-fetcher.py" 2>/dev/null; then
            chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
            echo -e "${GREEN}[OK] Quota fetcher downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install quota fetcher${NC}"
        fi
    fi

    # Install unified-server.py (serves static files + proxies API)
    echo "Installing unified server..."
    UNIFIED_SRC="$(dirname "$0")/unified-server.py"
    if [ -f "$UNIFIED_SRC" ]; then
        cp "$UNIFIED_SRC" "$SCRIPTS_DIR/unified-server.py"
        chmod +x "$SCRIPTS_DIR/unified-server.py"
        echo -e "${GREEN}[OK] Unified server installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/unified-server.py" -o "$SCRIPTS_DIR/unified-server.py" 2>/dev/null; then
            chmod +x "$SCRIPTS_DIR/unified-server.py"
            echo -e "${GREEN}[OK] Unified server downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install unified server${NC}"
        fi
    fi

    # Install cp-db command
    echo "Installing cp-db feature..."
    
    # Determine dashboard open command
    OPEN_CMD="open" # macOS default
    if [ "$PLATFORM" == "linux" ]; then
        if command -v xdg-open >/dev/null 2>&1; then
            OPEN_CMD="xdg-open"
        elif command -v gnome-open >/dev/null 2>&1; then
            OPEN_CMD="gnome-open"
        else
            OPEN_CMD="echo 'Please open manually: '"
        fi
    elif [ "$PLATFORM" == "windows" ]; then
        OPEN_CMD="start"
    fi

    cat > "/tmp/cp-db" <<EOF
#!/bin/bash

# ── CLIProxy Dashboard Launcher ──
GREEN='\\033[0;32m'
RED='\\033[0;31m'
YELLOW='\\033[1;33m'
CYAN='\\033[0;36m'
BOLD='\\033[1m'
DIM='\\033[2m'
NC='\\033[0m'

TIMESTAMP=\$(date +%s)
DASHBOARD_URL="http://localhost:8317/dashboard.html?v=\$TIMESTAMP"
PORT=8317
QUOTA_FETCHER="\$HOME/.cliproxyapi/scripts/quota-fetcher.py"

echo -e "\${CYAN}\${BOLD}  ══  CLIProxy Dashboard  ══\${NC}"
echo ""

# Portable port check: tries ss, then netstat, then lsof
check_port() {
    local port=\$1
    if command -v ss &>/dev/null; then
        ss -tlnp 2>/dev/null | grep -q ":\$port "
        return \$?
    fi
    if command -v netstat &>/dev/null; then
        netstat -tlnp 2>/dev/null | grep -q ":\$port "
        return \$?
    fi
    if command -v lsof &>/dev/null; then
        lsof -i :\$port -sTCP:LISTEN &>/dev/null
        return \$?
    fi
    return 1
}

# Check if server is already running
if check_port \$PORT; then
    echo -e "\${GREEN}[OK] Server already running on port \$PORT\${NC}"
else
    echo -e "\${YELLOW}[!] Server not running, starting now...\${NC}"

    CP_START_CMD=""
    if command -v cp-start >/dev/null 2>&1; then
        CP_START_CMD="cp-start"
    elif [ -x "\$HOME/.cliproxyapi/scripts/start.sh" ]; then
        CP_START_CMD="\$HOME/.cliproxyapi/scripts/start.sh"
    fi

    if [ -n "\$CP_START_CMD" ]; then
        "\$CP_START_CMD" >/dev/null 2>&1 &
        echo -e "\${YELLOW}Waiting for server to start...\${NC}"

        for i in {1..10}; do
            sleep 1
            if check_port \$PORT; then
                echo -e "\${GREEN}[OK] Server started successfully\${NC}"
                break
            fi
            if [ \$i -eq 10 ]; then
                echo -e "\${RED}[ERROR] Server failed to start. Please check logs.\${NC}"
                exit 1
            fi
        done
    else
        echo -e "\${RED}[ERROR] cp-start command not found. Please install CLIProxy first.\${NC}"
        exit 1
    fi
fi

# Run quota fetcher to update dashboard data
if [ -f "\$QUOTA_FETCHER" ] && command -v python3 >/dev/null 2>&1; then
    echo -e "\${YELLOW}Fetching quota data...\${NC}"
    python3 "\$QUOTA_FETCHER" 2>/dev/null
    echo -e "\${GREEN}[OK] Quota data updated.\${NC}"
fi

# Setup cron job if not exists
CRON_CMD="*/10 * * * * /usr/bin/python3 \$HOME/.cliproxyapi/scripts/quota-fetcher.py >/dev/null 2>&1"
if ! crontab -l 2>/dev/null | grep -q "quota-fetcher.py"; then
    (crontab -l 2>/dev/null; echo "\$CRON_CMD") | crontab - 2>/dev/null
fi

echo ""
echo -e "\${YELLOW}Opening dashboard: \${BOLD}\$DASHBOARD_URL\${NC}"
echo ""

$OPEN_CMD "\$DASHBOARD_URL" >/dev/null 2>&1
echo -e "\${GREEN}[OK] Dashboard opened successfully!\${NC}"
EOF

    # Install cp-db to BIN_DIR instead of /usr/local/bin (no sudo required) to avoid Windows permission issues
    mv /tmp/cp-db "$BIN_DIR/cp-db"
    chmod +x "$BIN_DIR/cp-db"
    
    # Add BIN_DIR to path in shortcuts if not present, but for now we assume user adds it or run aliases
    
    echo -e "${GREEN}[OK] cp-db installed to $BIN_DIR/cp-db${NC}"


    # Clone & Build (with persistent source for faster updates)
    SOURCE_DIR="$CONFIG_DIR/temp_source"

    if [ -d "$SOURCE_DIR/.git" ]; then
        # Source exists - pull latest updates
        echo "Updating source repository..."
        cd "$SOURCE_DIR"
        git fetch origin
        git reset --hard origin/main
        cd - > /dev/null
        echo -e "${GREEN}[OK] Source updated to latest${NC}"
    else
        # Fresh clone
        echo "Cloning repository..."
        rm -rf "$SOURCE_DIR" 2>/dev/null
        if ! git clone --depth 1 https://github.com/router-for-me/CLIProxyAPIPlus.git "$SOURCE_DIR"; then
            echo -e "${RED}[Error] Failed to clone repository${NC}"
            exit 1
        fi
        echo -e "${GREEN}[OK] Repository cloned${NC}"
    fi

    echo "Building binary..."
    cd "$SOURCE_DIR"

    BINARY_NAME="cliproxyapi"
    if [ "$PLATFORM" == "windows" ]; then
        BINARY_NAME="cliproxyapi.exe"
    fi

    if ! go build -o "$BINARY_NAME" ./cmd/server; then
        echo -e "${RED}[Error] Failed to build binary${NC}"
        cd - > /dev/null
        exit 1
    fi
    mv -f "$BINARY_NAME" "$BIN_DIR/$BINARY_NAME"
    cd - > /dev/null

    echo -e "${GREEN}[OK] Binary built and installed successfully.${NC}"

    # Config - Only create if it doesn't exist
    if [ ! -f "$CONFIG_DIR/config.yaml" ]; then
        if [[ "$CONFIGURE_CUSTOM" =~ ^[Yy]$ ]]; then
            echo -e "${GREEN}[OK] Using custom configuration${NC}"
            echo "  Base URL: $CUSTOM_BASE_URL"
            echo "  API Key: $CUSTOM_API_KEY"
        else
            echo -e "${CYAN}[i] Using default configuration${NC}"
        fi
        
        cat > "$CONFIG_DIR/config.yaml" <<EOF
port: 8317
auth-dir: "$CONFIG_DIR"
api-keys:
  - "$CUSTOM_API_KEY"
remote-management:
  allow-remote: true
  secret-key: "$CUSTOM_API_KEY"
quota-exceeded:
  switch-project: true
  switch-preview-model: true
EOF
        echo -e "${GREEN}[OK] Created config.yaml${NC}"
        
        # Store base URL for later use in scripts if custom
        if [ "$CUSTOM_BASE_URL" != "http://localhost:8317" ]; then
            echo "$CUSTOM_BASE_URL" > "$CONFIG_DIR/.custom_base_url"
            echo "$CUSTOM_API_KEY" > "$CONFIG_DIR/.custom_api_key"
        fi
    else
        echo -e "${YELLOW}[!] config.yaml exists, preserving user settings${NC}"
    fi

    # Install start.sh script
    echo "Installing start script..."
    START_SRC="$(dirname "$0")/assets/scripts/start.sh"
    if [ -f "$START_SRC" ]; then
        cp "$START_SRC" "$SCRIPTS_DIR/start.sh"
        echo -e "${GREEN}[OK] Start script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/start.sh" -o "$SCRIPTS_DIR/start.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Start script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install start script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/start.sh"

    # Install login.sh script
    echo "Installing login script..."
    LOGIN_SRC="$(dirname "$0")/assets/scripts/login.sh"
    if [ -f "$LOGIN_SRC" ]; then
        cp "$LOGIN_SRC" "$SCRIPTS_DIR/login.sh"
        echo -e "${GREEN}[OK] Login script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/login.sh" -o "$SCRIPTS_DIR/login.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Login script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install login script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/login.sh"

    # Login URL Script (for VPS/headless - prints URL only, no browser)
        # Login-url script
    echo "Installing login-url script..."
    LOGIN_URL_SRC="$(dirname "$0")/assets/scripts/login-url.sh"
    if [ -f "$LOGIN_URL_SRC" ]; then
        cp "$LOGIN_URL_SRC" "$SCRIPTS_DIR/login-url.sh"
        echo -e "${GREEN}[OK] Login-url script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/login-url.sh" -o "$SCRIPTS_DIR/login-url.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Login-url script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install Login-url script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/login-url.sh"

    # Stop Script
    echo "Installing stop script..."
    STOP_SRC="$(dirname "$0")/assets/scripts/stop.sh"
    if [ -f "$STOP_SRC" ]; then
        cp "$STOP_SRC" "$SCRIPTS_DIR/stop.sh"
        echo -e "${GREEN}[OK] Stop script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/stop.sh" -o "$SCRIPTS_DIR/stop.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Stop script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install stop script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/stop.sh"

    # CP-Claude Script (Interactive + Auto-Start)
        # Cp-claude script
    echo "Installing cp-claude script..."
    CP_CLAUDE_SRC="$(dirname "$0")/assets/scripts/cp-claude.sh"
    if [ -f "$CP_CLAUDE_SRC" ]; then
        cp "$CP_CLAUDE_SRC" "$SCRIPTS_DIR/cp-claude.sh"
        echo -e "${GREEN}[OK] Cp-claude script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-claude.sh" -o "$SCRIPTS_DIR/cp-claude.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Cp-claude script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install Cp-claude script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-claude.sh"

    # Add Provider Script (Interactive + Auto-Start)
    echo "Installing cp-add-provider python script..."
    CP_ADD_PROVIDER_PY_SRC="$(dirname "$0")/assets/scripts/cp-add-provider.py"
    if [ -f "$CP_ADD_PROVIDER_PY_SRC" ]; then
        cp "$CP_ADD_PROVIDER_PY_SRC" "$SCRIPTS_DIR/cp-add-provider.py"
        echo -e "${GREEN}[OK] Cp-add-provider python script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-add-provider.py" -o "$SCRIPTS_DIR/cp-add-provider.py" 2>/dev/null; then
            echo -e "${GREEN}[OK] Cp-add-provider python script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install Cp-add-provider python script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-add-provider.py"

    # Cp-add-provider script
    echo "Installing cp-add-provider script..."
    CP_ADD_PROVIDER_SH_SRC="$(dirname "$0")/assets/scripts/cp-add-provider.sh"
    if [ -f "$CP_ADD_PROVIDER_SH_SRC" ]; then
        cp "$CP_ADD_PROVIDER_SH_SRC" "$SCRIPTS_DIR/cp-add-provider.sh"
        echo -e "${GREEN}[OK] Cp-add-provider script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-add-provider.sh" -o "$SCRIPTS_DIR/cp-add-provider.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Cp-add-provider script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install Cp-add-provider script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-add-provider.sh"

    # CP-OpenCode Script (Auto-Start + Live Model Refresh)
        # Cp-opencode script
    echo "Installing cp-opencode script..."
    CP_OPENCODE_SRC="$(dirname "$0")/assets/scripts/cp-opencode.sh"
    if [ -f "$CP_OPENCODE_SRC" ]; then
        cp "$CP_OPENCODE_SRC" "$SCRIPTS_DIR/cp-opencode.sh"
        echo -e "${GREEN}[OK] Cp-opencode script installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-opencode.sh" -o "$SCRIPTS_DIR/cp-opencode.sh" 2>/dev/null; then
            echo -e "${GREEN}[OK] Cp-opencode script downloaded from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not install Cp-opencode script${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-opencode.sh"

    # Install cp-droid script
    echo "Installing cp-droid script..."
    CP_DROID_SRC="$(dirname "$0")/assets/scripts/cp-droid.sh"
    if [ -f "$CP_DROID_SRC" ]; then
        cp "$CP_DROID_SRC" "$SCRIPTS_DIR/cp-droid.sh"
        echo -e "${GREEN}[OK] cp-droid installed from local assets${NC}"
    else
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/cp-droid.sh" -o "$SCRIPTS_DIR/cp-droid.sh" 2>/dev/null; then
            chmod +x "$SCRIPTS_DIR/cp-droid.sh"
            echo -e "${GREEN}[OK] cp-droid installed from GitHub${NC}"
        else
            echo -e "${YELLOW}[!] Could not download cp-droid.sh from GitHub${NC}"
        fi
    fi
    chmod +x "$SCRIPTS_DIR/cp-droid.sh"

    # Droid Config Injection - Fetch available models from API
    DROID_FILE="$HOME/.factory/config.json"
    mkdir -p "$(dirname "$DROID_FILE")"

    # Generate models dynamically from CLIProxy API
    echo -e "${YELLOW}Fetching available models from CLIProxy...${NC}"

    # Create Python script to fetch and format models
    python3 - <<'PYSCRIPT'
import json
import urllib.request
import os

try:
    # Try to fetch models from running CLIProxy server
    req = urllib.request.Request(
        "http://localhost:8317/v1/models",
        headers={"Authorization": "Bearer sk-dummy"}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        data = json.loads(response.read().decode())
        models = data.get("data", [])
except:
    # Fallback to empty - will be populated on first cp-db/cp-claude run
    models = []

# Model display name mapping
display_names = {
    "gemini-claude-opus-4-5-thinking": "Claude Opus 4.5 Thinking",
    "gemini-claude-sonnet-4-5-thinking": "Claude Sonnet 4.5 Thinking",
    "gemini-claude-sonnet-4-5": "Claude Sonnet 4.5",
    "gemini-3-pro-preview": "Gemini 3 Pro",
    "gemini-3-pro-image-preview": "Gemini 3 Pro Image",
    "gemini-2.5-flash": "Gemini 2.5 Flash",
    "gemini-2.5-flash-lite": "Gemini 2.5 Flash Lite",
    "gemini-3-flash": "Gemini 3 Flash",
    "gemini-2.5-computer-use-preview-10-2025": "Gemini Computer Use",
    "gpt-oss-120b-medium": "GPT-OSS 120B Medium",
    # Copilot models
    "claude-opus-4.5": "Claude Opus 4.5 [Copilot]",
    "claude-sonnet-4.5": "Claude Sonnet 4.5 [Copilot]",
    "gpt-5-mini": "GPT-5 Mini [Copilot]",
    "gpt-4.5": "GPT-4.5 [Copilot]",
    # Codex models
    "gpt-5.1-codex-max": "GPT-5.1 Codex Max [Codex]",
    # Kiro models
    "kiro-claude-opus-4.5": "Claude Opus 4.5 [Kiro]",
    "kiro-claude-sonnet-4.5": "Claude Sonnet 4.5 [Kiro]",
    "kiro-claude-sonnet-4": "Claude Sonnet 4 [Kiro]",
    "kiro-claude-haiku-4.5": "Claude Haiku 4.5 [Kiro]",
    # Qwen models
    "qwen3-coder-plus": "Qwen3 Coder Plus [Qwen]",
    # iFlow models
    "glm-4.6": "GLM 4.6 [iFlow]",
    # Gemini CLI models
    "gemini-2.5-pro": "Gemini 2.5 Pro [Gemini]",
}

# Provider prefix mapping for display
provider_tags = {
    "antigravity": "[Antigravity]",
    "copilot": "[Copilot]",
    "github-copilot": "[Copilot]",
    "codex": "[Codex]",
    "kiro": "[Kiro]",
    "qwen": "[Qwen]",
    "iflow": "[iFlow]",
    "gemini": "[Gemini]",
    "claude": "[Claude]",
}

custom_models = []
for m in models:
    model_id = m.get("id", "")
    owner = m.get("owned_by", "unknown")

    # Get display name
    if model_id in display_names:
        display = display_names[model_id]
    else:
        # Auto-generate display name
        display = model_id.replace("-", " ").title()

    # Add provider tag if not already in display name
    tag = provider_tags.get(owner, f"[{owner.title()}]")
    if tag not in display:
        display = f"{display} {tag}"

    custom_models.append({
        "model_display_name": display,
        "model": model_id,
        "base_url": "http://localhost:8317/v1",
        "api_key": "sk-dummy",
        "provider": "openai"
    })

# Write to temp file
output = {"custom_models": custom_models}
with open("/tmp/cliproxy_new_models.json", "w") as f:
    json.dump(output, f, indent=4)

print(f"Found {len(custom_models)} models from CLIProxy")
PYSCRIPT

    if [ ! -f "$DROID_FILE" ]; then
        cp "/tmp/cliproxy_new_models.json" "$DROID_FILE"
        echo -e "${GREEN}[OK] Droid config created.${NC}"
    else
        echo -e "${YELLOW}[!] config.json exists, checking for missing models...${NC}"

        MERGE_UTIL="/tmp/merge_config_$$.go"
        if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/merge-config.go" -o "$MERGE_UTIL"; then
            go run "$MERGE_UTIL" "$DROID_FILE" "/tmp/cliproxy_new_models.json"
            rm -f "$MERGE_UTIL"
        else
            echo -e "${RED}[Error] Failed to download config merger. Skipping model merge.${NC}"
        fi
    fi
    rm -f "/tmp/cliproxy_new_models.json"

    # Download quota-fetcher.py and setup cron
    echo -e "${YELLOW}Setting up quota fetcher...${NC}"
    if curl -fsSL "https://raw.githubusercontent.com/imrosyd/cliproxy-installer/main/assets/scripts/quota-fetcher.py" -o "$SCRIPTS_DIR/quota-fetcher.py" 2>/dev/null; then
        chmod +x "$SCRIPTS_DIR/quota-fetcher.py"
        echo -e "${GREEN}[OK] Quota fetcher installed${NC}"

        # Setup cron job (every 10 minutes)
        CRON_CMD="*/10 * * * * /usr/bin/python3 $HOME/.cliproxyapi/scripts/quota-fetcher.py >/dev/null 2>&1"
        if ! crontab -l 2>/dev/null | grep -q "quota-fetcher.py"; then
            (crontab -l 2>/dev/null; echo "$CRON_CMD") | crontab -
            echo -e "${GREEN}[OK] Cron job added (runs every 10 min)${NC}"
        fi
    fi

    setup_shortcuts

    # Skip optional installs if in update mode
    if [ "$SKIP_OPTIONAL" != "true" ]; then
        if [[ "$INSTALL_STATUSLINE" =~ ^[Yy]$ ]]; then
            install_claude_statusline
        fi

        if [[ "$INSTALL_SUPERPOWERS" =~ ^[Yy]$ ]]; then
            install_superpowers
        fi

        if [[ "$INSTALL_OPENCODE" =~ ^[Yy]$ ]]; then
            install_opencode
        fi

        if [[ "$INSTALL_DROID" =~ ^[Yy]$ ]]; then
            install_droid
        fi
    fi

    echo -e "${GREEN}${BOLD}  ══  Installation Complete!  ══${NC}"
    echo ""
    echo -e "  ${DIM}Available commands:${NC}"
    echo ""
    echo -e "  ${CYAN}cp-login${NC}       ${DIM}Login to a provider${NC}"
    echo -e "  ${CYAN}cp-login-url${NC}   ${DIM}Login (URL / headless)${NC}"
    echo -e "  ${CYAN}cp-start${NC}       ${DIM}Start the proxy server${NC}"
    echo -e "  ${CYAN}cp-stop${NC}        ${DIM}Stop the proxy server${NC}"
    echo -e "  ${CYAN}cp-update${NC}      ${DIM}Update CLIProxy${NC}"
    echo -e "  ${CYAN}cp-claude${NC}      ${DIM}Launch Claude Code${NC}"
    echo -e "  ${CYAN}cp-opencode${NC}    ${DIM}Launch OpenCode${NC}"
    echo -e "  ${CYAN}cp-droid${NC}       ${DIM}Launch Android IDE${NC}"
    echo -e "  ${CYAN}cp-db${NC}          ${DIM}Open Dashboard${NC}"
    echo -e "  ${CYAN}cp-uninstall${NC}   ${DIM}Uninstall CLIProxy${NC}"
    echo ""

    # Auto-source shell configuration to apply new aliases
    echo -e "${YELLOW}Applying changes to current shell...${NC}"

    if [[ "$SHELL" == *"zsh"* ]]; then
        [ -f "$HOME/.zshrc" ] && source "$HOME/.zshrc" 2>/dev/null
    elif [[ "$SHELL" == *"fish"* ]]; then
        [ -f "$HOME/.config/fish/config.fish" ] && source "$HOME/.config/fish/config.fish" 2>/dev/null
    else
        [ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc" 2>/dev/null
    fi

    echo -e "${GREEN}[OK] Shell aliases loaded!${NC}"
    echo ""

    echo -e "${YELLOW}Restarting shell...${NC}"
    sleep 1
    exec "$SHELL" -i
}

# --- Main Execution ---
# Wrapped in main() to ensure all functions are defined before execution,
# especially when piped through curl | bash

main() {

if [[ "$1" == "-update" ]]; then
    echo -e "${CYAN}${BOLD}  ══  CLIProxy Auto Update  ══${NC}"
    echo ""

    install_dependencies
    auto_update_claude_code
    install_cliproxy "true" "true"

    echo -e "${YELLOW}>>> Updating Claude Statusline...${NC}"
    install_claude_statusline || true

    echo -e "${YELLOW}>>> Updating Superpowers...${NC}"
    install_superpowers || true

    echo -e "${YELLOW}>>> Updating OpenCode...${NC}"
    install_opencode || true

    echo -e "${YELLOW}>>> Updating Droid...${NC}"
    install_droid || true

    echo -e "${GREEN}[OK] Auto update complete (core + tools).${NC}"
    exit 0
fi

# Exit if we somehow got here after update (failsafe)
if [[ "$1" == "-update" ]]; then
    exit 0
fi

# --- Main Menu ---

clear
PLATFORM=$(detect_os)

# Platform icon
case "$PLATFORM" in
    linux)   PLATFORM_ICON="🐧" ;;
    macos)   PLATFORM_ICON="🍎" ;;
    windows) PLATFORM_ICON="🪟" ;;
    *)       PLATFORM_ICON="💻" ;;
esac

echo -e "${CYAN}${BOLD}  ══  CLIProxy Installer Manager  ══${NC}"
echo ""
echo -e "  ${DIM}Platform :${NC} ${PLATFORM_ICON}  ${BOLD}${PLATFORM}${NC}"
echo ""
echo -e "  ${BOLD}${GREEN}1${NC}  Install Dependencies        ${DIM}Git & Go${NC}"
echo -e "  ${BOLD}${GREEN}2${NC}  Install / Update CLIProxy   ${DIM}Core binary & scripts${NC}"
echo -e "  ${BOLD}${YELLOW}3${NC}  Full Install                ${DIM}Recommended for first run${NC}"
echo -e "  ${BOLD}${RED}4${NC}  Exit"
echo ""
echo -ne "  ${BOLD}›${NC} Select ${DIM}(1-4)${NC}: "
read choice < /dev/tty
echo ""

case $choice in
    1) install_dependencies ;;
    2)
        if [ -d "$HOME/.cliproxyapi" ]; then
            echo -e "${CYAN}[i] Existing installation detected, running update mode (preserve config/auth)${NC}"
            install_cliproxy "true" "true"
        else
            install_cliproxy
        fi
        ;;
    3)
        install_dependencies
        if [ -d "$HOME/.cliproxyapi" ]; then
            echo -e "${CYAN}[i] Existing installation detected, running update mode (preserve config/auth)${NC}"
            install_cliproxy "true" "true"
        else
            install_cliproxy
        fi
        ;;
    4) exit 0 ;;
    *) echo "Invalid choice." ;;
esac

}

main "$@"
